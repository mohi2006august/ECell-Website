---
// Would You Rather: Founder Edition — a stack of dilemma cards. Pick a side
// (click, arrow keys, or swipe) and the card flies off to reveal the next.
// Client-side only; tracks your picks for a little end summary.
interface Props { eyebrow?: string; title?: string; description?: string; }
const {
  eyebrow = 'Would you rather',
  title = 'Founder edition',
  description = 'Startup dilemmas with no right answer. Pick a side — swipe, click, or use ← →.',
} = Astro.props as Props;

const dilemmas = [
  { a: 'Raise a big VC round', b: 'Bootstrap forever' },
  { a: 'Solo founder', b: 'Co-founder team' },
  { a: '1,000 true fans', b: '1,000,000 casual users' },
  { a: 'Ship fast, break things', b: 'Slow and polished' },
  { a: 'Famous but broke startup', b: 'Boring but profitable' },
  { a: 'Build the product', b: 'Sell the product' },
  { a: 'Idea person', b: 'Execution person' },
  { a: 'Work from a garage', b: 'Fancy co-working space' },
  { a: 'Viral overnight', b: 'Steady 5% every week' },
  { a: 'Mentor 100 founders', b: 'Be mentored by one legend' },
];
---

<section id="would-you-rather" class="container mx-auto px-6 py-14 md:py-20 relative z-10">
  <div class="max-w-2xl mb-8">
    <p class="font-pixel text-xs text-red-200/80 mb-4">{eyebrow}</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
  </div>

  <div class="wyr-stage" data-wyr style={`--total:${dilemmas.length}`}>
    <div class="wyr-deck" data-wyr-deck>
      {dilemmas.map((d, i) => (
        <article class="wyr-card" data-wyr-card data-index={i} style={`--n:${i}`}>
          <button type="button" class="wyr-side wyr-a" data-wyr-choose="a" aria-label={`Would you rather ${d.a}`}>
            <span class="wyr-key font-pixel">A</span>
            <span class="wyr-text">{d.a}</span>
          </button>
          <span class="wyr-or font-pixel" aria-hidden="true">OR</span>
          <button type="button" class="wyr-side wyr-b" data-wyr-choose="b" aria-label={`Would you rather ${d.b}`}>
            <span class="wyr-key font-pixel">B</span>
            <span class="wyr-text">{d.b}</span>
          </button>
        </article>
      ))}
    </div>

    <div class="wyr-done" data-wyr-done hidden>
      <p class="wyr-done-title font-jakarta">That’s all of them 🎉</p>
      <p class="wyr-done-sub font-inter" data-wyr-summary></p>
      <button type="button" class="wyr-replay" data-wyr-replay>
        <iconify-icon icon="solar:refresh-linear" width="16" height="16"></iconify-icon>
        Play again
      </button>
    </div>

    <p class="wyr-progress font-pixel" data-wyr-progress></p>
  </div>
</section>

<style>
  .wyr-stage {
    position: relative;
    max-width: 40rem;
    margin: 0 auto;
  }
  .wyr-deck {
    position: relative;
    height: 20rem;
  }

  .wyr-card {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    gap: 0.6rem;
    padding: 0.6rem;
    border-radius: 1.25rem;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(150deg, #1c0906, #0a0302);
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.55);
    transform: translateY(calc(var(--depth, 0) * 10px)) scale(calc(1 - var(--depth, 0) * 0.04));
    transition: transform 300ms ease, opacity 300ms ease;
    touch-action: pan-y;
  }
  .wyr-card.is-gone-a { transform: translateX(-130%) rotate(-16deg); opacity: 0; }
  .wyr-card.is-gone-b { transform: translateX(130%) rotate(16deg); opacity: 0; }
  .wyr-card[hidden] { display: none; }

  .wyr-side {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(248, 113, 113, 0.14);
    background: rgba(255, 255, 255, 0.015);
    color: #fff;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: transform 160ms ease, border-color 160ms ease, background 220ms ease;
  }
  .wyr-side::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(185, 28, 28, 0.5), rgba(249, 115, 22, 0.4));
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .wyr-side:hover { transform: translateY(-3px); border-color: rgba(248, 113, 113, 0.5); }
  .wyr-side:hover::before { opacity: 0.16; }
  .wyr-side.is-picked::before { opacity: 0.32; }

  .wyr-key {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0.5rem;
    font-size: 0.7rem;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.35);
    background: rgba(127, 29, 29, 0.3);
  }
  .wyr-text {
    position: relative;
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    line-height: 1.15;
  }
  .wyr-or {
    align-self: center;
    font-size: 0.7rem;
    color: rgba(254, 202, 202, 0.55);
  }

  .wyr-progress {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: rgba(254, 202, 202, 0.6);
  }

  .wyr-done {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    gap: 0.6rem;
    text-align: center;
    border-radius: 1.25rem;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(150deg, rgba(30, 8, 5, 0.85), rgba(10, 3, 2, 0.9));
  }
  .wyr-done-title { font-size: 1.6rem; font-weight: 600; color: #fff; }
  .wyr-done-sub { color: rgb(209 213 219); }
  .wyr-replay {
    justify-self: center;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    clip-path: polygon(0.72rem 0, 100% 0, 100% calc(100% - 0.72rem), calc(100% - 0.72rem) 100%, 0 100%, 0 0.72rem);
    padding: 0.6rem 1.3rem;
    color: rgb(254 226 226);
    font-family: 'Prosto One', system-ui, sans-serif;
    background: rgba(10, 2, 2, 0.24);
    box-shadow: inset 0 0 0 1.4px rgba(254, 202, 202, 0.58);
    transition: transform 150ms ease, background 150ms ease, color 150ms ease, box-shadow 150ms ease;
  }

  .wyr-replay:hover {
    transform: translateY(-1px);
    color: #fff;
    background: rgba(127, 29, 29, 0.58);
    box-shadow: inset 0 0 0 1.4px rgba(254, 202, 202, 0.8), 0 0 18px rgba(248, 113, 113, 0.2);
  }

  @media (max-width: 560px) {
    .wyr-card { grid-template-columns: 1fr; grid-auto-rows: 1fr auto 1fr; }
    .wyr-deck { height: 26rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wyr-card { transition: opacity 200ms ease; }
    .wyr-card.is-gone-a, .wyr-card.is-gone-b { transform: none; }
  }
</style>

<script>
  (() => {
    const stage = document.querySelector<HTMLElement>('[data-wyr]');
    if (!stage) return;
    const cards = Array.from(stage.querySelectorAll<HTMLElement>('[data-wyr-card]'));
    const doneEl = stage.querySelector<HTMLElement>('[data-wyr-done]');
    const summaryEl = stage.querySelector<HTMLElement>('[data-wyr-summary]');
    const progressEl = stage.querySelector<HTMLElement>('[data-wyr-progress]');
    const replayBtn = stage.querySelector<HTMLButtonElement>('[data-wyr-replay]');
    const total = cards.length;

    let idx = 0;
    let picks = { a: 0, b: 0 };

    const paint = () => {
      cards.forEach((c, i) => {
        const depth = i - idx;
        c.hidden = depth < 0 || depth > 2;
        c.style.setProperty('--depth', String(Math.max(0, depth)));
        c.style.zIndex = String(total - i);
      });
      if (progressEl) progressEl.textContent = idx < total ? `${idx + 1} / ${total}` : '';
    };

    const choose = (choice: 'a' | 'b') => {
      const card = cards[idx];
      if (!card) return;
      picks[choice]++;
      card.querySelector(`.wyr-${choice}`)?.classList.add('is-picked');
      card.classList.add(choice === 'a' ? 'is-gone-a' : 'is-gone-b');
      idx++;
      window.setTimeout(() => {
        if (idx >= total) finish();
        else paint();
      }, 260);
    };

    const finish = () => {
      cards.forEach((c) => (c.hidden = true));
      if (progressEl) progressEl.textContent = '';
      if (summaryEl) {
        const lean = picks.a === picks.b ? 'a perfectly balanced founder' : picks.a > picks.b ? 'more of an A-type founder' : 'more of a B-type founder';
        summaryEl.textContent = `You picked A ${picks.a}× and B ${picks.b}× — ${lean}.`;
      }
      if (doneEl) doneEl.hidden = false;
    };

    stage.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-wyr-choose]') as HTMLElement | null;
      if (btn) choose(btn.dataset.wyrChoose as 'a' | 'b');
    });

    document.addEventListener('keydown', (e) => {
      if (idx >= total) return;
      const rect = stage.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > window.innerHeight) return; // only when in view
      if (e.key === 'ArrowLeft') { e.preventDefault(); choose('a'); }
      if (e.key === 'ArrowRight') { e.preventDefault(); choose('b'); }
    });

    // Basic swipe on the top card.
    let startX = 0, dragging = false;
    stage.addEventListener('pointerdown', (e) => {
      if (idx >= total) return;
      dragging = true; startX = e.clientX;
    });
    stage.addEventListener('pointerup', (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 60) choose(dx < 0 ? 'a' : 'b');
    });

    replayBtn?.addEventListener('click', () => {
      idx = 0; picks = { a: 0, b: 0 };
      cards.forEach((c) => { c.classList.remove('is-gone-a', 'is-gone-b'); c.querySelectorAll('.is-picked').forEach((s) => s.classList.remove('is-picked')); });
      if (doneEl) doneEl.hidden = true;
      paint();
    });

    paint();
  })();
</script>
