---
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';

interface Props {
  title?: string;
  showPreloader?: boolean;
}

const {
  title = 'E-Cell VJIT',
  showPreloader = false
} = Astro.props as Props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Climate+Crisis&family=Notable&family=Pixelify+Sans:wght@400;500;600;700&family=Prosto+One&display=swap" rel="stylesheet" />
  </head>
  <body class:list={["min-h-screen flex flex-col bg-black text-white font-inter selection:bg-red-600/30", { loading: showPreloader }] }>
    {showPreloader && <Preloader />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CustomCursor />
  </body>
</html>
