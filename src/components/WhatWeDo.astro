---
interface DomainItem {
  icon: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  domains?: DomainItem[];
}

const { domains = [
  {
    icon: 'solar:rocket-2-linear',
    title: 'Workshops',
    description: 'Hands-on sessions on startups, technology, and practical execution skills.',
    tags: ['Hands-on', 'Skill-building']
  },
  {
    icon: 'solar:code-square-linear',
    title: 'Hackathons',
    description: 'Build and test ideas under real constraints, collaborating with peers to ship fast.',
    tags: ['Team-based', 'Ship fast']
  },
  {
    icon: 'solar:notebook-linear',
    title: 'Mentorships',
    description: 'Guidance from founders, alumni, and professionals who shape ideas into outcomes.',
    tags: ['1-on-1', 'Founders']
  },
  {
    icon: 'solar:microphone-3-linear',
    title: 'Programs',
    description: 'Structured initiatives that move students from concept to execution with a clear roadmap.',
    tags: ['Roadmap', 'Long-term']
  }
] } = Astro.props as Props;
---

<section id="domains" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="lg:grid lg:grid-cols-[220px_minmax(0,1fr)] lg:gap-10">
    <div class="plane-lane" aria-hidden="true">
      <span class="plane-stop" data-plane-stop></span>
    </div>

    <div class="domains-content">
      <div class="max-w-3xl mb-10 lg:ml-auto lg:text-right">
        <p class="font-pixel text-xs text-red-200/80 mb-4">Opportunities</p>
        <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">Ways to learn, build and grow</h2>
        <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">Hands-on tracks that take students from curiosity to execution.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
        {domains.map((domain, index) => (
          <article class="domain-card glass rounded-xl p-5 md:p-6 group hover:border-red-500/30 transition-all">
            <div class="flex items-start justify-between mb-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-500/10 text-red-400 group-hover:bg-red-500/20 transition-colors">
                <iconify-icon icon={domain.icon} width="26" height="26"></iconify-icon>
              </span>
              <span class="font-jakarta text-sm text-red-200/50 tracking-widest">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <h3 class="text-xl font-jakarta font-semibold mb-2">{domain.title}</h3>
            <p class="text-gray-300 font-inter text-sm md:text-base leading-relaxed mb-4">{domain.description}</p>
            <div class="flex flex-wrap gap-2">
              {domain.tags.map((tag) => (
                <span class="rounded-full border border-red-500/20 bg-red-950/30 px-2.5 py-1 text-[0.68rem] font-inter uppercase tracking-wider text-red-100/80">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .domain-card:hover {
    transform: translateY(-3px);
  }

  @media (min-width: 1024px) {
    .domains-content {
      max-width: min(100%, 58rem);
      margin-left: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .domain-card:hover {
      transform: none;
    }
  }
</style>
