---
export const prerender = false;

import ConsoleLayout from '../../../../layouts/ConsoleLayout.astro';
import EventForm from '../../../../components/console/EventForm.astro';
import { supabaseAdmin } from '../../../../lib/supabaseAdmin.js';
import { eventFormDraft, parseEventForm } from '../../../../lib/parseEventForm.js';

const { id } = Astro.params;
let errorMessage = '';
let submittedEvent = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  submittedEvent = eventFormDraft(formData);

  try {
    const eventData = parseEventForm(formData);
    const { error } = await supabaseAdmin.from('events').update(eventData).eq('id', id);

    if (error) {
      errorMessage = error.message;
    } else {
      return Astro.redirect('/console');
    }
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Invalid form data.';
  }
}

const { data: event, error: fetchError } = await supabaseAdmin
  .from('events')
  .select('*')
  .eq('id', id)
  .single();
---

<ConsoleLayout title="Edit Event">
  <a href="/console" class="text-sm text-gray-400 hover:text-white transition-colors mb-6 inline-block">&larr; Back to Events</a>

  {fetchError || !event ? (
    <p class="text-red-400 font-inter text-sm">Event not found.</p>
  ) : (
    <>
      <h1 class="text-2xl font-jakarta font-semibold tracking-tight mb-6">Edit: {event.title}</h1>
      {errorMessage && <p class="text-red-400 font-inter text-sm mb-4">{errorMessage}</p>}
      <EventForm event={submittedEvent ?? event} action={`/console/events/${id}/edit`} submitLabel="Save Changes" />
    </>
  )}
</ConsoleLayout>
