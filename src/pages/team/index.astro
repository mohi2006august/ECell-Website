---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundShader from '../../components/BackgroundShader.astro';
import Navbar from '../../components/Navbar.astro';
import TeamCard from '../../components/TeamCard.astro';
import teamData from '../../../team.json';

const administration = teamData.administration ?? [];
const core = teamData.core;
const president = core.find((member) => member.role.toLowerCase() === 'president');
const vicePresident = core.find((member) => {
  const role = member.role.toLowerCase();
  return role.includes('vice-president') || role.includes('vice president') || role.includes('associate president');
});
const topLeadership = [president, vicePresident].filter(Boolean);
const leadIds = new Set(topLeadership.map((member) => member.id));
const otherLeads = core.filter((member) => !leadIds.has(member.id));

const teamLinks = [
  { label: 'Tech', href: '/team/tech' },
  { label: 'Digital', href: '/team/digital' },
  { label: 'Creative', href: '/team/creative' },
  { label: 'HR and Documentation', href: '/team/documentation' },
  { label: 'Marketing', href: '/team/marketing' },
  { label: 'Event Management', href: '/team/event-management' }
];
---

<BaseLayout title="E-Cell VJIT | Core Team">
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 py-12 md:py-16 relative z-10">
    <div class="max-w-4xl mx-auto mb-10 md:mb-12 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Core Team</p>
      <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-4">Leadership and contacts powering E-Cell VJIT</h1>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
        Meet the core team driving entrepreneurship programs, campus innovation, and community growth. For official communication, reach us at ecell@vjit.ac.in.
      </p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-8 md:mb-10">
      <span class="team-stat-pill glass px-4 py-2 text-xs uppercase tracking-[0.2em] text-red-200/90">Core Members {core.length}</span>
      <span class="team-stat-pill glass px-4 py-2 text-xs uppercase tracking-[0.2em] text-red-200/90">Domain Leads {otherLeads.length}</span>
    </div>

    <div class="team-section-shell glass noise-overlay p-6 md:p-8 mb-8 md:mb-10">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4 text-center">Institutional Leadership</p>
      <div class="team-grid-optimized mx-auto grid max-w-7xl grid-cols-1 md:grid-cols-3 gap-6 md:gap-7 justify-items-center">
        {administration.map((member, index) => (
          <div class="w-full max-w-sm">
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
    </div>

    <div class="fire-line-divider" aria-hidden="true"></div>

    <div class="team-section-shell glass noise-overlay p-6 md:p-8 mb-8 md:mb-10">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4 text-center">Core Leadership</p>
      <div class="leadership-lane md:hidden max-w-4xl mx-auto">
        {topLeadership.map((member, index) => (
          <div>
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
      <div class="team-grid-optimized hidden md:grid max-w-5xl mx-auto grid-cols-1 md:grid-cols-2 gap-6 md:gap-7 place-items-center">
        {topLeadership.map((member, index) => (
          <div class="w-full max-w-sm">
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
    </div>

    <div class="fire-line-divider" aria-hidden="true"></div>

    <div class="team-section-shell glass noise-overlay p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4 text-center">Domain Leads</p>
      <div class="team-grid-optimized mx-auto grid max-w-7xl grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 md:gap-7 justify-items-center">
        {otherLeads.map((member, index) => (
          <div class="w-full max-w-sm">
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container mx-auto px-6 pb-16 md:pb-24 relative z-10">
    <div class="fire-line-divider" aria-hidden="true"></div>
    <div class="team-section-shell glass noise-overlay p-8 md:p-10 max-w-6xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Explore Teams</p>
      <h2 class="text-2xl md:text-4xl font-jakarta font-semibold tracking-tight mb-6">Browse members by domain</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto text-left">
        {teamLinks.map((teamLink) => (
          <a href={teamLink.href} class="team-domain-link glass px-5 py-4 font-inter text-gray-200 hover:text-white hover:border-red-500/30 transition-all">
            {teamLink.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-section-shell {
    border: 1px solid rgba(248, 113, 113, 0.18);
    clip-path: polygon(1.2rem 0, 100% 0, 100% calc(100% - 1.2rem), calc(100% - 1.2rem) 100%, 0 100%, 0 1.2rem);
  }

  .team-stat-pill,
  .team-domain-link {
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
  }
</style>
