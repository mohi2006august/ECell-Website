---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackgroundShader from '../../../components/BackgroundShader.astro';
import Navbar from '../../../components/Navbar.astro';
import { supabase } from '../../../lib/supabase.js';

export async function getStaticPaths() {
  const { data: events, error } = await supabase.from('events').select('slug, title');

  if (error) {
    console.error('Failed to load events for static paths:', error.message);
    return [];
  }

  return (events ?? []).map((event) => ({
    params: { slug: event.slug },
    props: { eventTitle: event.title },
  }));
}

const { eventTitle } = Astro.props;
---

<BaseLayout title={`E-Cell VJIT | Registered for ${eventTitle}`}>
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 py-16 md:py-20 relative z-10 max-w-4xl">
    <div id="loading-state" class="text-center">
      <p class="text-gray-300 font-inter">Loading your tickets...</p>
    </div>

    <div id="error-state" class="text-center hidden">
      <h1 class="text-3xl font-jakarta font-semibold tracking-tight mb-3">We couldn't find that registration</h1>
      <p class="text-gray-300 font-inter mb-6">The link looks incomplete or incorrect.</p>
      <a href="/events" class="hero-action hero-action-primary inline-flex items-center gap-2 text-white font-inter font-medium text-base rounded-full px-8 py-4">
        Back to Events
      </a>
    </div>

    <div id="ticket-state" class="hidden">
      <div class="text-center mb-8">
        <span class="events-ghost-label mx-auto mb-5">Registration confirmed</span>
        <h1 id="confirmation-heading" class="text-3xl md:text-4xl font-jakarta font-semibold tracking-tight mb-3"></h1>
        <p id="confirmation-subtext" class="text-gray-300 font-inter"></p>
        <p id="email-status" class="text-xs text-gray-500 font-inter mt-3"></p>
      </div>

      <div id="download-all-wrap" class="text-center mb-6 hidden">
        <button id="download-all-btn" class="download-btn download-btn-primary">
          <iconify-icon icon="solar:download-linear" width="18" height="18"></iconify-icon>
          Download all tickets
        </button>
      </div>

      <div id="tickets-container" class="ticket-wallet-grid"></div>

      <div class="text-center mt-8">
        <a href="/events" class="text-sm font-inter text-gray-300 hover:text-white transition-colors">Back to Events</a>
      </div>
    </div>
  </section>
</BaseLayout>

<template id="ticket-card-template">
  <div class="wallet-pass">
    <div class="wallet-pass-top">
      <div>
        <p class="wallet-kicker">E-CELL VJIT PASS</p>
        <h2 class="ticket-event-title"></h2>
      </div>
      <span class="wallet-live-dot">
        <span></span>
        LIVE
      </span>
    </div>

    <div class="wallet-pass-body">
      <div class="wallet-main-info">
        <p class="attendee-name-label"></p>
        <span class="ticket-event-meta"></span>
      </div>

      <div class="wallet-qr-wrap">
        <canvas class="qr-canvas"></canvas>
      </div>
    </div>

    <div class="wallet-pass-cut" aria-hidden="true"></div>

    <div class="wallet-pass-bottom">
      <div class="wallet-field">
        <span>Email</span>
        <strong class="ticket-email-text"></strong>
      </div>
      <div class="wallet-field">
        <span>Phone</span>
        <strong class="ticket-phone-text"></strong>
      </div>
      <div class="wallet-field">
        <span>Team</span>
        <strong class="ticket-team-text"></strong>
      </div>
      <div class="wallet-field wallet-field-wide">
        <span>Ticket ID</span>
        <strong class="ticket-id-text"></strong>
      </div>
      <button class="download-btn download-btn-secondary download-single-btn">
        <iconify-icon icon="solar:download-linear" width="16" height="16"></iconify-icon>
        Download ticket
      </button>
      <div class="whatsapp-join-wrap hidden">
        <p class="whatsapp-join-copy"></p>
        <a class="whatsapp-join-btn" target="_blank" rel="noopener noreferrer">
          <iconify-icon icon="mdi:whatsapp" width="17" height="17"></iconify-icon>
          Join WhatsApp group
        </a>
      </div>
    </div>
  </div>
</template>

<style>
  .hidden {
    display: none;
  }

  .events-ghost-label {
    width: fit-content;
    border-radius: 999px;
    padding: 0.28rem 0.58rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.22);
    background: rgba(127, 29, 29, 0.14);
    margin: 0 auto;
  }

  .hero-action {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(135deg, rgba(185, 28, 28, 0.96), rgba(249, 115, 22, 0.95));
  }

  .ticket-wallet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .wallet-pass {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 1.65rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      radial-gradient(circle at 15% 0%, rgba(254, 202, 202, 0.34), transparent 26%),
      radial-gradient(circle at 100% 18%, rgba(249, 115, 22, 0.28), transparent 32%),
      linear-gradient(145deg, rgba(127, 29, 29, 0.96), rgba(22, 4, 3, 0.98) 54%, rgba(3, 1, 1, 0.96));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 24px 70px rgba(0, 0, 0, 0.44);
  }

  .wallet-pass::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(120deg, transparent 0 34%, rgba(255, 255, 255, 0.08) 42%, transparent 52%),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 7px);
    opacity: 0.7;
  }

  .wallet-pass-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.35rem 1.35rem 1rem;
  }

  .wallet-kicker,
  .wallet-live-dot,
  .wallet-field span {
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .wallet-kicker {
    margin-bottom: 0.45rem;
    color: rgb(254, 226, 226);
    font-size: 0.72rem;
  }

  .ticket-event-title {
    color: white;
    font-size: clamp(1.35rem, 3vw, 2.1rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .wallet-live-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: fit-content;
    border-radius: 999px;
    padding: 0.36rem 0.62rem;
    color: rgb(255, 241, 242);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(0, 0, 0, 0.24);
    font-size: 0.68rem;
  }

  .wallet-live-dot span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: rgb(34, 197, 94);
    box-shadow: 0 0 14px rgba(34, 197, 94, 0.85);
  }

  .wallet-pass-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: end;
    padding: 0 1.35rem 1.25rem;
  }

  .attendee-name-label {
    margin-bottom: 0.55rem;
    color: white;
    font-size: clamp(1.6rem, 4vw, 2.65rem);
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .ticket-event-meta {
    display: block;
    color: rgb(254, 226, 226);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .wallet-qr-wrap {
    border-radius: 1.15rem;
    padding: 0.65rem;
    background: white;
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.08),
      0 16px 34px rgba(0, 0, 0, 0.32);
  }

  .wallet-pass-cut {
    position: relative;
    height: 1px;
    margin: 0 1.45rem;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent);
  }

  .wallet-pass-cut::before,
  .wallet-pass-cut::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 999px;
    background: #050101;
    transform: translateY(-50%);
  }

  .wallet-pass-cut::before {
    left: -2.3rem;
  }

  .wallet-pass-cut::after {
    right: -2.3rem;
  }

  .wallet-pass-bottom {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    padding: 1.25rem 1.35rem 1.35rem;
    background: rgba(0, 0, 0, 0.22);
  }

  .wallet-field {
    min-width: 0;
  }

  .wallet-field-wide {
    grid-column: 1 / -1;
  }

  .wallet-field span {
    display: block;
    margin-bottom: 0.28rem;
    color: rgb(252, 165, 165);
    font-size: 0.68rem;
  }

  .wallet-field strong {
    display: block;
    overflow-wrap: anywhere;
    color: rgb(243, 244, 246);
    font-size: 0.82rem;
    font-weight: 400;
  }

  /* global.css has a bare `canvas { position: fixed; ... }` rule for the background
     shader canvas — override it here so the QR canvas renders inline in the card. */
  .qr-canvas {
    position: static;
    top: auto;
    left: auto;
    z-index: auto;
    display: block;
    width: 9.5rem;
    height: 9.5rem;
    padding: 0;
    background: white;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 999px;
    padding: 0.6rem 1.2rem;
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: transform 150ms ease, background-color 150ms ease;
  }

  .download-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .download-btn-primary {
    background: linear-gradient(135deg, rgba(185, 28, 28, 0.96), rgba(249, 115, 22, 0.95));
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .download-btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .download-btn-secondary {
    grid-column: 1 / -1;
    background: rgba(255, 255, 255, 0.04);
    color: rgb(254 226 226);
    border: 1px solid rgba(248, 113, 113, 0.22);
  }

  .download-btn-secondary:hover:not(:disabled) {
    background: rgba(127, 29, 29, 0.18);
  }

  .whatsapp-join-wrap {
    grid-column: 1 / -1;
    border-radius: 1rem;
    border: 1px solid rgba(34, 197, 94, 0.24);
    background: rgba(20, 83, 45, 0.14);
    padding: 0.85rem;
  }

  .whatsapp-join-copy {
    margin: 0 0 0.7rem;
    color: rgb(220, 252, 231);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .whatsapp-join-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    border-radius: 999px;
    padding: 0.65rem 1rem;
    color: rgb(5, 46, 22);
    background: rgb(134, 239, 172);
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.82rem;
    transition: transform 150ms ease, background-color 150ms ease;
  }

  .whatsapp-join-btn:hover {
    transform: translateY(-1px);
    background: rgb(187, 247, 208);
  }

  @media (max-width: 640px) {
    .wallet-pass-body {
      grid-template-columns: 1fr;
    }

    .wallet-qr-wrap {
      width: fit-content;
    }
  }
</style>

<script>
  import { supabase } from '../../../lib/supabase.js';
  import QRCode from 'qrcode';
  import { generateTicketsPdf, downloadBlob } from '../../../lib/ticketPdf.js';

  const loadingState = document.getElementById('loading-state');
  const errorState = document.getElementById('error-state');
  const ticketState = document.getElementById('ticket-state');
  const ticketsContainer = document.getElementById('tickets-container');
  const cardTemplate = document.getElementById('ticket-card-template');
  const headingEl = document.getElementById('confirmation-heading');
  const subtextEl = document.getElementById('confirmation-subtext');
  const downloadAllWrap = document.getElementById('download-all-wrap');
  const downloadAllBtn = document.getElementById('download-all-btn');
  const emailStatus = document.getElementById('email-status');

  function showError() {
    loadingState?.classList.add('hidden');
    errorState?.classList.remove('hidden');
  }

  function slugify(text: string) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }

  async function withButtonBusy(button: Element | null, label: string, task: () => Promise<void>) {
    if (!(button instanceof HTMLButtonElement)) {
      await task();
      return;
    }
    const original = button.innerHTML;
    button.disabled = true;
    button.textContent = label;
    try {
      await task();
    } finally {
      button.disabled = false;
      button.innerHTML = original;
    }
  }

  const ticketIds = (new URLSearchParams(window.location.search).get('tickets') ?? '')
    .split(',')
    .map((id) => id.trim())
    .filter(Boolean);

  if (ticketIds.length === 0) {
    showError();
  } else {
    const { data: registrations, error } = await supabase
      .from('registrations')
      .select('name, email, phone, ticket_id, team_name, events (title, date, time, venue, whatsapp_group_link)')
      .in('ticket_id', ticketIds);

    if (error || !registrations || registrations.length === 0) {
      showError();
    } else {
      loadingState?.classList.add('hidden');
      ticketState?.classList.remove('hidden');

      if (headingEl) {
        headingEl.textContent =
          registrations.length === 1 ? `You're in, ${registrations[0].name}!` : "Your team is registered!";
      }
      if (subtextEl) {
        subtextEl.textContent =
          registrations.length === 1
            ? 'Check your email for a copy of this confirmation. Bring the QR code below to check in at the venue.'
            : "Each teammate's ticket is below — everyone should bring their own individual QR code to check in at the venue.";
      }

      if (registrations.length > 1) {
        downloadAllWrap?.classList.remove('hidden');
      }

      const eventTitleForFile = registrations[0]?.events?.title ?? 'event';

      downloadAllBtn?.addEventListener('click', () => {
        withButtonBusy(downloadAllBtn, 'Preparing PDF...', async () => {
          const blob = await generateTicketsPdf(registrations);
          downloadBlob(blob, `${slugify(eventTitleForFile)}-tickets.pdf`);
        });
      });

      for (const registration of registrations) {
        if (!(cardTemplate instanceof HTMLTemplateElement) || !ticketsContainer) continue;

        const clone = cardTemplate.content.cloneNode(true) as DocumentFragment;
        const nameLabel = clone.querySelector('.attendee-name-label');
        const titleEl = clone.querySelector('.ticket-event-title');
        const metaEl = clone.querySelector('.ticket-event-meta');
        const idEl = clone.querySelector('.ticket-id-text');
        const emailEl = clone.querySelector('.ticket-email-text');
        const phoneEl = clone.querySelector('.ticket-phone-text');
        const teamEl = clone.querySelector('.ticket-team-text');
        const canvas = clone.querySelector('.qr-canvas');
        const downloadBtn = clone.querySelector('.download-single-btn');
        const whatsappWrap = clone.querySelector('.whatsapp-join-wrap');
        const whatsappCopy = clone.querySelector('.whatsapp-join-copy');
        const whatsappBtn = clone.querySelector('.whatsapp-join-btn');

        const event = registration.events;

        if (nameLabel) nameLabel.textContent = registration.name;
        if (titleEl) titleEl.textContent = event?.title ?? '';
        if (metaEl && event) {
          const date = new Date(event.date).toLocaleDateString('en-IN', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          });
          metaEl.textContent = `${date}${event.time ? ` · ${event.time}` : ''} · ${event.venue}`;
        }
        if (idEl) idEl.textContent = registration.ticket_id;
        if (emailEl) emailEl.textContent = registration.email;
        if (phoneEl) phoneEl.textContent = registration.phone || 'Not provided';
        if (teamEl) teamEl.textContent = registration.team_name || 'Solo';

        if (event?.whatsapp_group_link && whatsappWrap instanceof HTMLElement && whatsappBtn instanceof HTMLAnchorElement) {
          whatsappWrap.classList.remove('hidden');
          whatsappBtn.href = event.whatsapp_group_link;
          if (whatsappCopy) {
            whatsappCopy.textContent = `Join the "${event.title ?? 'event'}" event WhatsApp group for updates.`;
          }
        }

        downloadBtn?.addEventListener('click', () => {
          withButtonBusy(downloadBtn, 'Preparing...', async () => {
            const blob = await generateTicketsPdf([registration]);
            downloadBlob(blob, `${slugify(event?.title ?? 'event')}-${slugify(registration.name)}-ticket.pdf`);
          });
        });

        ticketsContainer.appendChild(clone);

        if (canvas instanceof HTMLCanvasElement) {
          await QRCode.toCanvas(canvas, registration.ticket_id, { width: 220, margin: 1 });
        }
      }

      if (emailStatus) emailStatus.textContent = 'Emailing your ticket...';
      try {
        const response = await fetch('/api/send-ticket-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticketIds }),
        });
        const result = await response.json();
        if (response.ok && result.sent?.length) {
          if (emailStatus) emailStatus.textContent = 'Ticket emailed to you as well.';
        } else if (emailStatus) {
          emailStatus.textContent = '';
        }
      } catch {
        if (emailStatus) emailStatus.textContent = '';
      }
    }
  }
</script>
