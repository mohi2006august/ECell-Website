---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundShader from '../../components/BackgroundShader.astro';
import Navbar from '../../components/Navbar.astro';
import { supabase } from '../../lib/supabase.js';
import { getRegistrationStatus } from '../../lib/eventStatus.js';

export const prerender = false;

const { data: events, error } = await supabase
  .from('events')
  .select('id, slug, title, short_description, date, time, venue, mode, poster_url, registration_open, registration_deadline, max_participants, is_featured')
  .order('date', { ascending: true });

const { data: registrationRows, error: registrationsError } = await supabase
  .from('registrations')
  .select('event_id');

if (error) {
  console.error('Failed to load events:', error.message);
}

if (registrationsError) {
  console.error('Failed to load registration counts:', registrationsError.message);
}

const hasEvents = Array.isArray(events) && events.length > 0;
const countsByEvent = new Map();
for (const row of registrationRows ?? []) {
  countsByEvent.set(row.event_id, (countsByEvent.get(row.event_id) ?? 0) + 1);
}

const formatEventDate = (date: string) => new Date(date).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
});

const registrationStatusFor = (event: Record<string, any>) =>
  getRegistrationStatus(event, countsByEvent.get(event.id) ?? 0);
---

<BaseLayout title="E-Cell VJIT | Events">
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
    <div class="max-w-4xl mb-10 md:mb-14">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Events</p>
      <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-4">Where the next campus moment will light up</h1>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed max-w-2xl">
        {hasEvents
          ? 'A living archive of hackathons, workshops, speaker sessions, and campus initiatives.'
          : 'This space is intentionally empty for now, but designed to become a living archive of hackathons, workshops, speaker sessions, and campus initiatives.'}
      </p>
    </div>

    {hasEvents && (
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 md:gap-7 mb-12 md:mb-16">
        {events.map((event) => (
          <a href={`/events/${event.slug}`} class="event-card-cut noise-overlay">
            <figure class="event-poster-preview">
              {event.poster_url ? (
                <img src={event.poster_url} alt={`${event.title} poster`} loading="lazy" decoding="async" />
              ) : (
                <div class="event-poster-fallback">
                  <span>Poster</span>
                  <strong>{event.title}</strong>
                </div>
              )}
            </figure>
            <div class="event-card-copy">
              <span class="events-ghost-label w-fit">{event.mode}</span>
              <h3>{event.title}</h3>
              <p>{event.short_description}</p>
              <div class="event-card-meta">
                <span>{formatEventDate(event.date)}</span>
                <span>{event.venue}</span>
              </div>
              {registrationStatusFor(event).canRegister && (
                <span class="event-card-status">Registration open</span>
              )}
              {!registrationStatusFor(event).canRegister && (
                <span class="event-card-status event-card-status-muted">
                  {registrationStatusFor(event).reason === 'full' ? 'Registration full' : 'Registration closed'}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="glass noise-overlay events-stage p-6 md:p-8 lg:p-10 mb-8 md:mb-10" style={hasEvents ? 'display:none' : undefined}>
      <div class="events-stage-inner p-6 md:p-8 lg:p-10">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
          <div class="max-w-2xl">
            <span class="events-pill inline-flex items-center gap-2 mb-5">
              <span class="h-2 w-2 rounded-full bg-red-400 animate-pulse"></span>
              Empty archive
            </span>
            <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">A cinematic stage reserved for future E-Cell events</h2>
            <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed max-w-xl">
              The page stays clean until the first event lands, then it will naturally become the place where students discover what’s happening next.
            </p>
          </div>

          <div class="events-orbit-shell mx-auto lg:mx-0" aria-hidden="true">
            <div class="events-orbit events-orbit-one"></div>
            <div class="events-orbit events-orbit-two"></div>
            <div class="events-orbit events-orbit-three"></div>
            <div class="events-orbit-core">
              <iconify-icon icon="solar:calendar-minimalistic-linear" width="34" height="34"></iconify-icon>
            </div>
          </div>
        </div>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
          <article class="events-ghost-card">
            <span class="events-ghost-label">Hackathons</span>
            <h3>High-energy build spaces</h3>
            <p>Reserved for challenge-driven sprints, prototypes, and fast-moving student teams.</p>
          </article>
          <article class="events-ghost-card">
            <span class="events-ghost-label">Workshops</span>
            <h3>Learning with momentum</h3>
            <p>A future home for practical sessions on startup thinking, problem solving, and execution.</p>
          </article>
          <article class="events-ghost-card">
            <span class="events-ghost-label">Speaker Sessions</span>
            <h3>Founder stories in focus</h3>
            <p>For conversations with builders, mentors, and leaders once the event calendar begins.</p>
          </article>
        </div>
      </div>
    </div>

  </section>
</BaseLayout>

<style>
  .events-stage {
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(165deg, rgba(24, 5, 4, 0.92), rgba(10, 2, 2, 0.92));
    clip-path: polygon(1.35rem 0, 100% 0, 100% calc(100% - 1.35rem), calc(100% - 1.35rem) 100%, 0 100%, 0 1.35rem);
  }

  .events-stage-inner {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: radial-gradient(120% 120% at 50% 0%, rgba(185, 28, 28, 0.2) 0%, rgba(9, 9, 11, 0.25) 45%, rgba(6, 2, 2, 0.52) 100%);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
  }

  .event-card-cut {
    display: grid;
    min-height: 100%;
    color: inherit;
    border: 1px solid rgba(248, 113, 113, 0.2);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 34%),
      linear-gradient(165deg, rgba(28, 5, 3, 0.92), rgba(9, 2, 2, 0.88));
    clip-path: polygon(1.15rem 0, 100% 0, 100% calc(100% - 1.15rem), calc(100% - 1.15rem) 100%, 0 100%, 0 1.15rem);
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .event-card-cut:hover {
    transform: translateY(-4px);
    border-color: rgba(254, 202, 202, 0.38);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.34), 0 0 24px rgba(248, 113, 113, 0.12);
  }

  .event-poster-preview {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid rgba(248, 113, 113, 0.14);
    background: rgba(255, 255, 255, 0.035);
  }

  .event-poster-preview::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 42%, rgba(0, 0, 0, 0.62));
    pointer-events: none;
  }

  .event-poster-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.08) contrast(1.05);
    transition: transform 260ms ease, filter 260ms ease;
  }

  .event-card-cut:hover .event-poster-preview img {
    transform: scale(1.045);
    filter: saturate(1.16) contrast(1.08) brightness(1.04);
  }

  .event-poster-fallback {
    height: 100%;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 0.65rem;
    padding: 1.25rem;
    text-align: center;
    background:
      radial-gradient(circle at 50% 36%, rgba(248, 113, 113, 0.22), transparent 34%),
      linear-gradient(135deg, rgba(127, 29, 29, 0.48), rgba(7, 2, 2, 0.92));
  }

  .event-poster-fallback span {
    color: rgba(254, 202, 202, 0.75);
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .event-poster-fallback strong {
    color: white;
    font-size: 1.25rem;
    line-height: 1.18;
  }

  .event-card-copy {
    display: flex;
    min-height: 15rem;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.25rem;
  }

  .event-card-copy h3 {
    color: white;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .event-card-copy p {
    color: rgba(209, 213, 219, 0.86);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .event-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    color: rgba(209, 213, 219, 0.74);
    font-size: 0.78rem;
  }

  .event-card-status {
    color: rgba(254, 202, 202, 0.86);
    font-family: var(--font-pixel);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .event-card-status-muted {
    color: rgba(209, 213, 219, 0.62);
  }

  .events-pill {
    border: 1px solid rgba(248, 113, 113, 0.28);
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    color: rgb(254 202 202);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(127, 29, 29, 0.16);
  }

  .events-orbit-shell {
    position: relative;
    width: min(100%, 310px);
    aspect-ratio: 1 / 1;
    border-radius: 999px;
  }

  .events-orbit,
  .events-orbit-core {
    position: absolute;
    inset: 0;
    border-radius: 999px;
  }

  .events-orbit {
    border: 1px solid rgba(248, 113, 113, 0.14);
  }

  .events-orbit-one {
    inset: 0.5rem;
    animation: orbitPulse 10s ease-in-out infinite;
  }

  .events-orbit-two {
    inset: 1.6rem;
    border-color: rgba(251, 146, 60, 0.18);
    animation: orbitPulse 12s ease-in-out infinite reverse;
  }

  .events-orbit-three {
    inset: 3.2rem;
    border-color: rgba(254, 202, 202, 0.12);
  }

  .events-orbit-core {
    inset: 4.4rem;
    display: grid;
    place-items: center;
    color: rgb(254 202 202);
    background: radial-gradient(circle, rgba(185, 28, 28, 0.26), rgba(9, 9, 11, 0.2));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .events-ghost-card {
    min-height: 180px;
    border: 1px dashed rgba(248, 113, 113, 0.18);
    background: linear-gradient(165deg, rgba(127, 29, 29, 0.16), rgba(6, 2, 2, 0.36));
    padding: 1.15rem;
    clip-path: polygon(0.85rem 0, 100% 0, 100% calc(100% - 0.85rem), calc(100% - 0.85rem) 100%, 0 100%, 0 0.85rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.45rem;
  }

  .events-ghost-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: rgb(255 247 247);
  }

  .events-ghost-card p {
    color: rgb(209 213 219);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .events-ghost-label {
    width: fit-content;
    border-radius: 999px;
    padding: 0.28rem 0.58rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.22);
    background: rgba(127, 29, 29, 0.14);
  }

  .events-flow-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
  }

  .events-flow-item span {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(248, 113, 113, 0.22);
    background: rgba(127, 29, 29, 0.18);
    color: rgb(254 202 202);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .events-flow-item p {
    color: rgb(244 244 245);
    font-family: var(--font-display);
    font-weight: 500;
  }

  .events-info-panel {
    border: 1px solid rgba(248, 113, 113, 0.18);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
  }

  @keyframes orbitPulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.02);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .events-orbit-one,
    .events-orbit-two {
      animation: none;
    }
  }
</style>
