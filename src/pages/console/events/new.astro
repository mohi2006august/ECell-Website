---
export const prerender = false;

import ConsoleLayout from '../../../layouts/ConsoleLayout.astro';
import EventForm from '../../../components/console/EventForm.astro';
import { supabaseAdmin } from '../../../lib/supabaseAdmin.js';
import { parseEventForm } from '../../../lib/parseEventForm.js';

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  try {
    const eventData = parseEventForm(formData);
    const { error } = await supabaseAdmin.from('events').insert(eventData);

    if (error) {
      errorMessage = error.message;
    } else {
      return Astro.redirect('/console');
    }
  } catch (err) {
    errorMessage = err instanceof Error ? `Invalid JSON in an advanced field: ${err.message}` : 'Invalid form data.';
  }
}
---

<ConsoleLayout title="New Event">
  <a href="/console" class="text-sm text-gray-400 hover:text-white transition-colors mb-6 inline-block">&larr; Back to Events</a>
  <h1 class="text-2xl font-jakarta font-semibold tracking-tight mb-6">New Event</h1>

  {errorMessage && <p class="text-red-400 font-inter text-sm mb-4">{errorMessage}</p>}

  <EventForm action="/console/events/new" submitLabel="Create Event" />
</ConsoleLayout>
