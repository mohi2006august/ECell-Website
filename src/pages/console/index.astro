---
export const prerender = false;

import ConsoleLayout from '../../layouts/ConsoleLayout.astro';
import { supabaseAdmin } from '../../lib/supabaseAdmin.js';
import { getRegistrationStatus } from '../../lib/eventStatus.js';

const { data: events, error } = await supabaseAdmin
  .from('events')
  .select('id, title, slug, date, status, registration_open, registration_deadline, max_participants, is_team_event')
  .order('date', { ascending: false });

const { data: registrationRows } = await supabaseAdmin.from('registrations').select('event_id');

const countsByEvent = new Map<string, number>();
for (const row of registrationRows ?? []) {
  countsByEvent.set(row.event_id, (countsByEvent.get(row.event_id) ?? 0) + 1);
}
---

<ConsoleLayout title="Events">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-jakarta font-semibold tracking-tight">Events</h1>
    <a
      href="/console/events/new"
      class="rounded-full bg-red-500 hover:bg-red-400 transition-colors text-white font-inter font-medium text-sm px-5 py-2.5"
    >
      + New Event
    </a>
  </div>

  {error && <p class="text-red-400 font-inter text-sm mb-4">Failed to load events: {error.message}</p>}

  <div class="overflow-x-auto rounded-xl border border-white/10">
    <table class="w-full text-sm font-inter text-left">
      <thead class="bg-white/5 text-gray-400 uppercase text-xs tracking-wider">
        <tr>
          <th class="px-4 py-3">Title</th>
          <th class="px-4 py-3">Date</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3">Registration</th>
          <th class="px-4 py-3">Team Event</th>
          <th class="px-4 py-3">Registrations</th>
          <th class="px-4 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/10">
        {(events ?? []).map((event) => (
          <tr>
            <td class="px-4 py-3 font-medium text-white">{event.title}</td>
            <td class="px-4 py-3 text-gray-300">{new Date(event.date).toLocaleDateString('en-IN')}</td>
            <td class="px-4 py-3 text-gray-300 capitalize">{event.status}</td>
            <td class="px-4 py-3">
              <form method="POST" action="/console/actions/toggle-registration" class="inline">
                <input type="hidden" name="eventId" value={event.id} />
                <input type="hidden" name="current" value={String(event.registration_open)} />
                <button
                  type="submit"
                  class={`rounded-full px-3 py-1 text-xs font-medium ${
                    event.registration_open
                      ? 'bg-green-500/15 text-green-300 border border-green-500/30'
                      : 'bg-white/5 text-gray-400 border border-white/10'
                  }`}
                >
                  {event.registration_open ? 'Open' : 'Closed'}
                </button>
              </form>
              <p class="text-xs text-gray-500 mt-1">
                Public: {getRegistrationStatus(event, countsByEvent.get(event.id) ?? 0).canRegister
                  ? 'Open'
                  : getRegistrationStatus(event, countsByEvent.get(event.id) ?? 0).reason === 'full'
                    ? 'Full'
                    : 'Closed'}
              </p>
            </td>
            <td class="px-4 py-3 text-gray-300">{event.is_team_event ? 'Yes' : 'No'}</td>
            <td class="px-4 py-3 text-gray-300">
              {countsByEvent.get(event.id) ?? 0}{event.max_participants ? ` / ${event.max_participants}` : ''}
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-3">
                <a href={`/console/events/${event.id}/edit`} class="text-red-300 hover:text-red-200">Edit</a>
                <a href={`/console/events/${event.id}/registrations`} class="text-red-300 hover:text-red-200">Registrations</a>
              </div>
            </td>
          </tr>
        ))}
        {(events ?? []).length === 0 && (
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-gray-500">No events yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</ConsoleLayout>
