---
import '../styles/global.css';

interface Props {
  title?: string;
  showNav?: boolean;
  brandLabel?: string;
  homeHref?: string;
  logoutHref?: string;
}

const {
  title = 'Console',
  showNav = true,
  brandLabel = 'E-Cell Console',
  homeHref = '/console',
  logoutHref = '/console/logout',
} = Astro.props as Props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>E-Cell VJIT | {title}</title>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-black text-white font-inter">
    {showNav && (
      <header class="border-b border-white/10 bg-black/60">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
          <a href={homeHref} class="font-jakarta font-semibold tracking-tight text-white">
            {brandLabel}
          </a>
          <nav class="flex items-center gap-5 text-sm font-inter text-gray-300">
            <a href={homeHref} class="hover:text-white transition-colors">Home</a>
            <a href={logoutHref} class="hover:text-white transition-colors">Log out</a>
          </nav>
        </div>
      </header>
    )}
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>
  </body>
</html>
