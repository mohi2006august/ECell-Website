---
export const prerender = false;

import ConsoleLayout from '../../../../layouts/ConsoleLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabaseAdmin.js';

const { id } = Astro.params;

const { data: event } = await supabaseAdmin.from('events').select('id, title').eq('id', id).single();
const { data: registrations, error } = await supabaseAdmin
  .from('registrations')
  .select('*')
  .eq('event_id', id)
  .order('created_at', { ascending: true });
---

<ConsoleLayout title={event ? `Registrations — ${event.title}` : 'Registrations'}>
  <a href="/console" class="text-sm text-gray-400 hover:text-white transition-colors mb-6 inline-block">&larr; Back to Events</a>

  {!event ? (
    <p class="text-red-400 font-inter text-sm">Event not found.</p>
  ) : (
    <>
      <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
        <h1 class="text-2xl font-jakarta font-semibold tracking-tight">{event.title} — Registrations ({(registrations ?? []).length})</h1>
        <div class="flex items-center gap-3">
          <input
            id="search-input"
            type="text"
            placeholder="Search name/email/team..."
            class="admin-input"
          />
          <a href={`/console/actions/export-registrations?eventId=${id}`} class="rounded-full bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-white font-inter text-sm px-4 py-2">
            Export CSV
          </a>
        </div>
      </div>

      {error && <p class="text-red-400 font-inter text-sm mb-4">Failed to load registrations: {error.message}</p>}

      <div class="overflow-x-auto rounded-xl border border-white/10">
        <table id="registrations-table" class="w-full text-sm font-inter text-left whitespace-nowrap">
          <thead class="bg-white/5 text-gray-400 uppercase text-xs tracking-wider">
            <tr>
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">Email</th>
              <th class="px-4 py-3">Phone</th>
              <th class="px-4 py-3">Roll No.</th>
              <th class="px-4 py-3">Branch</th>
              <th class="px-4 py-3">Year</th>
              <th class="px-4 py-3">Team</th>
              <th class="px-4 py-3">Payment</th>
              <th class="px-4 py-3">Checked In</th>
              <th class="px-4 py-3">Registered</th>
              <th class="px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10">
            {(registrations ?? []).map((reg) => (
              <tr class="registration-row" data-search={`${reg.name} ${reg.email} ${reg.team_name ?? ''}`.toLowerCase()}>
                <td class="px-4 py-3 text-white font-medium">{reg.name}{reg.is_team_leader && <span class="ml-1 text-xs text-red-300">(lead)</span>}</td>
                <td class="px-4 py-3 text-gray-300">{reg.email}</td>
                <td class="px-4 py-3 text-gray-300">{reg.phone ?? '—'}</td>
                <td class="px-4 py-3 text-gray-300">{reg.roll_number ?? '—'}</td>
                <td class="px-4 py-3 text-gray-300">{reg.branch ?? '—'}</td>
                <td class="px-4 py-3 text-gray-300">{reg.year_of_study ?? '—'}</td>
                <td class="px-4 py-3 text-gray-300">{reg.team_name ?? '—'}</td>
                <td class="px-4 py-3">
                  <button
                    class="toggle-payment-btn rounded-full px-3 py-1 text-xs font-medium border"
                    data-id={reg.id}
                    data-current={String(reg.payment_verified ?? false)}
                    class:list={[
                      reg.payment_verified
                        ? 'bg-green-500/15 text-green-300 border-green-500/30'
                        : 'bg-white/5 text-gray-400 border-white/10',
                    ]}
                  >
                    {reg.payment_verified ? 'Verified' : reg.payment_status ?? 'pending'}
                  </button>
                </td>
                <td class="px-4 py-3">
                  <button
                    class="toggle-checkin-btn rounded-full px-3 py-1 text-xs font-medium border"
                    data-id={reg.id}
                    data-current={String(reg.is_checked_in ?? false)}
                    class:list={[
                      reg.is_checked_in
                        ? 'bg-green-500/15 text-green-300 border-green-500/30'
                        : 'bg-white/5 text-gray-400 border-white/10',
                    ]}
                  >
                    {reg.is_checked_in ? 'Checked in' : 'Not yet'}
                  </button>
                </td>
                <td class="px-4 py-3 text-gray-400 text-xs">{new Date(reg.created_at).toLocaleString('en-IN')}</td>
                <td class="px-4 py-3">
                  <form method="POST" action="/console/actions/delete-registration" onsubmit="return confirm('Delete this registration? This cannot be undone.')">
                    <input type="hidden" name="registrationId" value={reg.id} />
                    <input type="hidden" name="eventId" value={id} />
                    <button type="submit" class="text-red-400 hover:text-red-300 text-xs">Delete</button>
                  </form>
                </td>
              </tr>
            ))}
            {(registrations ?? []).length === 0 && (
              <tr>
                <td colspan="11" class="px-4 py-8 text-center text-gray-500">No registrations yet.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </>
  )}
</ConsoleLayout>

<style>
  .admin-input {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 0.5rem 0.9rem;
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
  }
</style>

<script>
  const searchInput = document.getElementById('search-input');
  searchInput?.addEventListener('input', () => {
    const query = (searchInput as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll<HTMLElement>('.registration-row').forEach((row) => {
      const haystack = row.dataset.search ?? '';
      row.style.display = haystack.includes(query) ? '' : 'none';
    });
  });

  async function toggleField(button: Element, endpoint: string) {
    if (!(button instanceof HTMLButtonElement)) return;
    button.disabled = true;
    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ registrationId: button.dataset.id, current: button.dataset.current }),
      });
      const result = await response.json();
      if (response.ok) {
        location.reload();
      } else {
        alert(result.error ?? 'Something went wrong.');
        button.disabled = false;
      }
    } catch {
      alert('Something went wrong.');
      button.disabled = false;
    }
  }

  document.querySelectorAll('.toggle-checkin-btn').forEach((btn) => {
    btn.addEventListener('click', () => toggleField(btn, '/console/actions/toggle-checkin'));
  });
  document.querySelectorAll('.toggle-payment-btn').forEach((btn) => {
    btn.addEventListener('click', () => toggleField(btn, '/console/actions/toggle-payment'));
  });
</script>
