---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  navLinks?: NavLink[];
}

const { navLinks = [
  { label: 'Events', href: '/events' },
  { label: 'Team', href: '/team' },
  { label: 'Achievements', href: '/achievements' },
  { label: 'Contact', href: '/contact' },
] } = Astro.props as Props;
---

<nav class="navbar-shell container mx-auto px-4 sm:px-6 pt-3 md:pt-4 relative z-20">
  <div class="navbar-rim noise-overlay">
    <span class="navbar-frame-line navbar-frame-top" aria-hidden="true"></span>
    <span class="navbar-frame-line navbar-frame-bottom" aria-hidden="true"></span>
    <div class="navbar-glow" aria-hidden="true"></div>
    <div class="relative z-10 px-3 sm:px-4 md:px-5 py-3 md:py-4">
      <div class="navbar-row flex items-center justify-between gap-3 md:gap-4">
        <a href="/" class="navbar-brand group min-w-0">
          <span class="navbar-brand-main">E-CELL</span>
          <span class="navbar-brand-sub">VJIT</span>
        </a>

        <div class="hidden lg:flex navbar-center items-center gap-1.5 xl:gap-2">
          {navLinks.map((link) => (
            <a href={link.href} class="navbar-link">{link.label}</a>
          ))}
        </div>

        <div class="flex items-center gap-2 sm:gap-2.5">
          <a href="/interactions" class="navbar-cta hidden md:inline-flex items-center gap-1.5 stroke-button stroke-button-strong">
            Interactions
            <iconify-icon icon="solar:cursor-linear" width="15" height="15"></iconify-icon>
          </a>

          <button
            type="button"
            class="mobile-toggle inline-flex lg:hidden items-center justify-center p-2.5 text-white"
            aria-expanded="false"
            aria-controls="mobile-menu"
            data-mobile-toggle
          >
            <span class="sr-only">Toggle navigation menu</span>
            <iconify-icon icon="solar:menu-dots-bold" width="18" height="18"></iconify-icon>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="mobile-panel lg:hidden" data-mobile-menu hidden>
        <div class="mobile-panel-shell mt-3 p-2.5">
          <div class="grid gap-2 sm:grid-cols-2">
            {navLinks.map((link) => (
              <a href={link.href} class="mobile-link">{link.label}</a>
            ))}
          </div>
          <div class="mt-2.5 flex flex-col sm:flex-row gap-2">
            <a href="/interactions" class="mobile-link mobile-link-cta">
              Interactions
              <iconify-icon icon="solar:cursor-linear" width="15" height="15"></iconify-icon>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<div class="nav-divider relative z-10"></div>

<script is:inline>
  (() => {
    const toggle = document.querySelector('[data-mobile-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');

    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', String(open));
      menu.hidden = !open;
      menu.classList.toggle('is-open', open);
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    document.addEventListener('click', (event) => {
      if (menu.hidden) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (menu.contains(target) || toggle.contains(target)) return;
      setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  })();
</script>

<style>
  .navbar-shell {
    position: sticky;
    top: 0;
    isolation: isolate;
    filter: drop-shadow(0 28px 44px rgba(0, 0, 0, 0.34));
  }

  .navbar-rim {
    --nav-cut: 1.85rem;
    position: relative;
    clip-path: polygon(
      var(--nav-cut) 0,
      calc(100% - var(--nav-cut)) 0,
      100% var(--nav-cut),
      100% calc(100% - 1.15rem),
      calc(100% - 1.15rem) 100%,
      1.15rem 100%,
      0 calc(100% - 1.15rem),
      0 var(--nav-cut)
    );
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent 42%),
      radial-gradient(80% 160% at 50% -55%, rgba(254, 202, 202, 0.16), transparent 54%),
      linear-gradient(100deg, rgba(12, 2, 2, 0.78), rgba(38, 7, 5, 0.9) 42%, rgba(10, 2, 2, 0.84));
    box-shadow:
      inset 0 0 0 1px rgba(254, 202, 202, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 -22px 42px rgba(0, 0, 0, 0.28);
    overflow: hidden;
  }

  .navbar-rim::before {
    content: '';
    position: absolute;
    inset: 1px;
    z-index: 0;
    clip-path: inherit;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background:
      repeating-linear-gradient(90deg, transparent 0 11px, rgba(255, 255, 255, 0.025) 11px 12px),
      radial-gradient(120% 90% at 0% 0%, rgba(248, 113, 113, 0.16), transparent 45%),
      radial-gradient(120% 90% at 100% 0%, rgba(251, 146, 60, 0.1), transparent 46%);
    pointer-events: none;
  }

  .navbar-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
  }

  .navbar-center {
    position: relative;
    justify-self: center;
    min-height: 3.25rem;
    padding: 0.42rem;
    clip-path: polygon(1.1rem 0, calc(100% - 1.1rem) 0, 100% 50%, calc(100% - 1.1rem) 100%, 1.1rem 100%, 0 50%);
    border: 1px solid rgba(254, 202, 202, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
      rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      0 18px 52px rgba(0, 0, 0, 0.32);
  }

  .navbar-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 120% at 10% 0%, rgba(239, 68, 68, 0.18) 0%, transparent 48%),
      radial-gradient(90% 100% at 90% 0%, rgba(251, 146, 60, 0.12) 0%, transparent 42%);
    pointer-events: none;
  }

  .navbar-frame-line {
    position: absolute;
    left: 7.5rem;
    right: 7.5rem;
    z-index: 2;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(254, 202, 202, 0.56), rgba(251, 146, 60, 0.28), transparent);
  }

  .navbar-frame-top {
    top: 0;
  }

  .navbar-frame-bottom {
    bottom: 0;
    opacity: 0.55;
  }

  .navbar-brand {
    display: inline-flex;
    flex-direction: column;
    gap: 0.05rem;
    line-height: 0.92;
    color: white;
    position: relative;
    padding: 0.38rem 0.85rem 0.35rem 0.65rem;
    border-left: 1px solid rgba(254, 202, 202, 0.18);
    transition: transform 180ms ease;
  }

  .navbar-brand::before {
    content: '';
    position: absolute;
    left: -0.15rem;
    top: 0.48rem;
    bottom: 0.48rem;
    width: 0.22rem;
    background: linear-gradient(180deg, #fecaca, #ef4444, #fb923c);
    border-radius: 999px;
    box-shadow: 0 0 14px rgba(248, 113, 113, 0.42);
  }

  .navbar-brand-main {
    font-family: 'Pixelify Sans', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-shadow: 0 0 18px rgba(248, 113, 113, 0.28);
    transition: color 180ms ease, text-shadow 180ms ease;
  }

  .navbar-brand-sub {
    width: fit-content;
    margin-left: 0.08rem;
    font-family: 'Pixelify Sans', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.34em;
    color: rgb(254 202 202 / 0.68);
  }

  .navbar-brand:hover .navbar-brand-main {
    color: rgb(254 226 226);
    text-shadow: 0 0 22px rgba(248, 113, 113, 0.44);
  }

  .navbar-brand:hover {
    transform: translateX(1px);
  }

  .navbar-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    clip-path: polygon(0.65rem 0, calc(100% - 0.65rem) 0, 100% 50%, calc(100% - 0.65rem) 100%, 0.65rem 100%, 0 50%);
    padding: 0.58rem 0.96rem;
    font-size: 0.9rem;
    font-family: 'Pixelify Sans', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(226 232 240 / 0.86);
    transition: color 180ms ease, background-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .navbar-link::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(248, 113, 113, 0.24), rgba(251, 146, 60, 0.14)),
      rgba(255, 255, 255, 0.025);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 210ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .navbar-link::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.38rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(248, 113, 113, 0.7), transparent);
    transform: scaleX(0);
    transition: transform 180ms ease;
  }

  .navbar-link:hover {
    color: rgb(254 226 226);
    transform: translateY(-1px);
    box-shadow: inset 0 0 0 1px rgba(254, 202, 202, 0.18);
  }

  .navbar-link:hover::before {
    transform: scaleX(1);
  }

  .navbar-link:hover::after {
    transform: scaleX(1);
  }

  .navbar-pulse {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: rgb(248 113 113);
    box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.45);
    animation: navbarPulse 1.8s ease-out infinite;
  }

  .navbar-cta,
  .mobile-link {
    font-family: 'Pixelify Sans', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .navbar-cta {
    min-width: 0;
    min-height: 2.35rem;
    padding: 0.55rem 1rem;
    font-size: 0.82rem;
  }

  .navbar-cta:hover,
  .mobile-link:hover {
    transform: translateY(-1px);
  }

  .mobile-toggle {
    clip-path: polygon(0.65rem 0, 100% 0, 100% calc(100% - 0.65rem), calc(100% - 0.65rem) 100%, 0 100%, 0 0.65rem);
    border: 0;
    background: rgba(255, 255, 255, 0.035);
    box-shadow: inset 0 0 0 1px rgba(254, 202, 202, 0.2);
    transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .mobile-toggle:hover {
    transform: translateY(-1px);
    background: rgba(127, 29, 29, 0.32);
    box-shadow: inset 0 0 0 1px rgba(254, 202, 202, 0.46), 0 0 18px rgba(248, 113, 113, 0.14);
  }

  .mobile-panel {
    overflow: hidden;
  }

  .mobile-panel-shell {
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
    border: 1px solid rgba(254, 202, 202, 0.16);
    background: rgba(8, 2, 2, 0.72);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .mobile-panel.is-open {
    animation: navbarDrop 240ms ease-out both;
  }

  .mobile-link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    clip-path: polygon(0.75rem 0, 100% 0, 100% calc(100% - 0.75rem), calc(100% - 0.75rem) 100%, 0 100%, 0 0.75rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.78rem 0.9rem;
    font-family: 'Pixelify Sans', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(226 232 240 / 0.9);
  }

  .mobile-link-emphasis {
    border-color: rgba(248, 113, 113, 0.2);
    background: rgba(239, 68, 68, 0.1);
    color: rgb(254 226 226);
  }

  .mobile-link-cta {
    border-color: rgba(251, 146, 60, 0.24);
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(251, 146, 60, 0.12));
    color: rgb(255 237 213);
  }

  .nav-divider {
    height: 1px;
    width: min(72rem, calc(100% - 3rem));
    margin: 0.78rem auto 0;
    background:
      linear-gradient(90deg, transparent, rgba(254, 202, 202, 0.2), rgba(248, 113, 113, 0.38), rgba(251, 146, 60, 0.18), transparent);
    box-shadow: 0 0 18px rgba(248, 113, 113, 0.18);
  }

  @keyframes navbarPulse {
    0% {
      box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.45);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(248, 113, 113, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(248, 113, 113, 0);
    }
  }

  @keyframes navbarDrop {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar-pulse,
    .mobile-panel.is-open {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .navbar-rim {
      --nav-cut: 1.1rem;
    }

    .navbar-frame-line {
      left: 4rem;
      right: 4rem;
    }

  }
</style>
