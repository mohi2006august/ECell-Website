---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundShader from '../components/BackgroundShader.astro';
import Navbar from '../components/Navbar.astro';
import teamData from '../../team.json';

const coreMembers = (teamData.core ?? []).slice(0, 8);

const channels = [
  {
    label: 'Email',
    value: 'ecell@vjit.ac.in',
    href: 'mailto:ecell@vjit.ac.in',
    icon: 'solar:letter-linear',
    note: 'Official communication'
  },
  {
    label: 'Instagram',
    value: '@ecell_vjit',
    href: 'https://www.instagram.com/ecell_vjit?igsh=MTM3c3ExdXVwaXBreg==',
    icon: 'mdi:instagram',
    note: 'Updates and reels'
  },
  {
    label: 'LinkedIn',
    value: 'E-Cell VJIT',
    href: 'https://www.linkedin.com/company/e-cell-vjit/about/',
    icon: 'mdi:linkedin',
    note: 'Announcements and network'
  },
  {
    label: 'YouTube',
    value: '@E-cellVJIT',
    href: 'https://www.youtube.com/@E-cellVJIT/videos',
    icon: 'mdi:youtube',
    note: 'Talks and event videos'
  }
];

const normalizeSocialUrl = (url: string | undefined, platform: 'github' | 'linkedin' | 'instagram') => {
  const trimmed = (url ?? '').trim();
  if (!trimmed) return '';
  if (/^https?:\/\//i.test(trimmed)) return trimmed;
  if (platform === 'instagram') return `https://instagram.com/${trimmed.replace(/^@/, '')}`;
  return `https://${trimmed}`;
};
---

<BaseLayout title="E-Cell VJIT | Contact">
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 pt-14 md:pt-20 pb-10 relative z-10">
    <div class="contact-hero">
      <div>
        <p class="font-pixel text-xs text-red-200/80 mb-4">Contact E-Cell</p>
        <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-5">Reach the people building the launchpad.</h1>
        <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed max-w-2xl">
          For collaborations, events, questions, or student-founder support, use the official channels or contact the core team leads directly.
        </p>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-6 pb-12 md:pb-16 relative z-10">
    <div class="contact-channel-grid">
      {channels.map((channel) => (
        <a href={channel.href} target={channel.href.startsWith('http') ? '_blank' : undefined} rel={channel.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="contact-channel-card">
          <span class="contact-channel-icon">
            <iconify-icon icon={channel.icon} width="24" height="24"></iconify-icon>
          </span>
          <span class="contact-channel-copy">
            <small>{channel.label}</small>
            <strong>{channel.value}</strong>
            <em>{channel.note}</em>
          </span>
          <iconify-icon icon="solar:arrow-right-up-linear" width="20" height="20" class="contact-channel-arrow"></iconify-icon>
        </a>
      ))}
    </div>
  </section>

  <section class="container mx-auto px-6 pb-20 md:pb-28 relative z-10">
    <div class="fire-line-divider" aria-hidden="true"></div>

    <div class="max-w-3xl mb-8 md:mb-10">
      <p class="font-pixel text-xs text-red-200/80 mb-4">Contact the team directly</p>
      <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">Core leads</h2>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">
        These cards are powered by the core team data. Add photos, socials, or contact details later and the cards will pick them up.
      </p>
    </div>

    <div class="contact-leads-grid">
      {coreMembers.map((member, index) => {
        const imageSource = member.image?.trim() || '/images/team-placeholder.svg';
        const linkedin = normalizeSocialUrl(member.socials?.linkedin, 'linkedin');
        const instagram = normalizeSocialUrl(member.socials?.instagram, 'instagram');
        const github = normalizeSocialUrl(member.socials?.github, 'github');
        return (
          <article class="contact-lead-card" style={`--lead-delay:${index * 55}ms;`}>
            <div class="contact-lead-photo">
              <img src={imageSource} alt={`${member.name} profile`} loading="lazy" decoding="async" />
            </div>
            <div class="contact-lead-body">
              <span class="contact-lead-role">{member.role}</span>
              <h3>{member.name}</h3>
              {member.tagline?.trim() ? <p>{member.tagline}</p> : <p>Core team contact details can be added here later.</p>}
              <div class="contact-lead-actions">
                {linkedin && <a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${member.name} LinkedIn`}><iconify-icon icon="mdi:linkedin" width="18" height="18"></iconify-icon></a>}
                {instagram && <a href={instagram} target="_blank" rel="noopener noreferrer" aria-label={`${member.name} Instagram`}><iconify-icon icon="mdi:instagram" width="18" height="18"></iconify-icon></a>}
                {github && <a href={github} target="_blank" rel="noopener noreferrer" aria-label={`${member.name} GitHub`}><iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon></a>}
                {!linkedin && !instagram && !github && <span>Socials pending</span>}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
    max-width: 58rem;
  }

  .contact-channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 1rem;
  }

  .contact-channel-card {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.9rem;
    align-items: center;
    min-height: 7rem;
    padding: 1rem;
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
    border: 1px solid rgba(254, 202, 202, 0.16);
    background: rgba(12, 3, 2, 0.54);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .contact-channel-card:hover {
    transform: translateY(-2px);
    border-color: rgba(254, 202, 202, 0.4);
    background: rgba(127, 29, 29, 0.24);
    box-shadow: 0 0 24px rgba(248, 113, 113, 0.12);
  }

  .contact-channel-icon {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    color: rgb(254 226 226);
    border: 1px solid rgba(248, 113, 113, 0.24);
    background: rgba(127, 29, 29, 0.2);
    clip-path: polygon(0.75rem 0, 100% 0, 100% calc(100% - 0.75rem), calc(100% - 0.75rem) 100%, 0 100%, 0 0.75rem);
  }

  .contact-channel-copy {
    min-width: 0;
    display: grid;
    gap: 0.2rem;
  }

  .contact-channel-copy small,
  .contact-lead-role {
    font-family: 'Pixelify Sans', monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(254, 202, 202, 0.76);
  }

  .contact-channel-copy strong {
    color: white;
    font-size: 1.05rem;
    overflow-wrap: anywhere;
  }

  .contact-channel-copy em {
    color: rgba(209, 213, 219, 0.72);
    font-size: 0.82rem;
    font-style: normal;
  }

  .contact-channel-arrow {
    color: rgba(254, 202, 202, 0.7);
  }

  .contact-leads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
  }

  .contact-lead-card {
    display: grid;
    grid-template-columns: 5.2rem minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    min-height: 9.4rem;
    padding: 0.9rem;
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
    border: 1px solid rgba(248, 113, 113, 0.17);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent 34%),
      rgba(10, 2, 2, 0.62);
    opacity: 0;
    transform: translateY(10px);
    animation: contactLeadIn 420ms ease-out forwards;
    animation-delay: var(--lead-delay, 0ms);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .contact-lead-card:hover {
    transform: translateY(-2px);
    border-color: rgba(254, 202, 202, 0.36);
    box-shadow: 0 0 24px rgba(248, 113, 113, 0.12);
  }

  .contact-lead-photo {
    aspect-ratio: 0.86;
    overflow: hidden;
    clip-path: polygon(0.9rem 0, 100% 0, 100% calc(100% - 0.9rem), calc(100% - 0.9rem) 100%, 0 100%, 0 0.9rem);
    border: 1px solid rgba(254, 202, 202, 0.2);
    background: rgba(255, 255, 255, 0.04);
  }

  .contact-lead-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .contact-lead-body {
    min-width: 0;
  }

  .contact-lead-role {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.62rem;
  }

  .contact-lead-body h3 {
    color: white;
    font-size: 1.05rem;
    line-height: 1.2;
    margin-bottom: 0.35rem;
  }

  .contact-lead-body p {
    color: rgba(209, 213, 219, 0.72);
    font-size: 0.78rem;
    line-height: 1.45;
    margin-bottom: 0.65rem;
  }

  .contact-lead-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    color: rgba(254, 202, 202, 0.72);
    font-family: 'Pixelify Sans', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-lead-actions a {
    width: 1.9rem;
    height: 1.9rem;
    display: grid;
    place-items: center;
    color: rgb(254 226 226);
    border: 1px solid rgba(248, 113, 113, 0.24);
    background: rgba(255, 255, 255, 0.035);
    transition: transform 150ms ease, background 150ms ease, border-color 150ms ease;
  }

  .contact-lead-actions a:hover {
    transform: translateY(-1px);
    background: rgba(127, 29, 29, 0.32);
    border-color: rgba(254, 202, 202, 0.46);
  }

  @keyframes contactLeadIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 560px) {
    .contact-lead-card {
      grid-template-columns: 4.8rem minmax(0, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-lead-card {
      animation: none;
    }

    .contact-lead-card {
      opacity: 1;
      transform: none;
    }
  }
</style>
