---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundShader from '../../components/BackgroundShader.astro';
import Navbar from '../../components/Navbar.astro';
import RetroReel from '../../components/RetroReel.astro';
---

<BaseLayout title="E-Cell VJIT | E-Cell TV">
  <BackgroundShader />
  <Navbar />

  <div class="container mx-auto px-6 pt-8 relative z-10">
    <a href="/interactions" class="inline-flex items-center gap-2 text-sm font-pixel text-red-200/80 hover:text-white transition-colors">
      <iconify-icon icon="solar:arrow-left-linear" width="15" height="15"></iconify-icon>
      All interactions
    </a>
  </div>

  <section id="tv" class="container mx-auto px-6 py-12 md:py-16 relative z-10">
    <div class="max-w-2xl mb-8">
      <p class="font-pixel text-xs text-red-200/80 mb-4">Now playing</p>
      <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">E-Cell TV</h2>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">
        Memories and moments from E-Cell, on loop. Flip channels, turn it up, go fullscreen.
      </p>
    </div>
    <RetroReel />
  </section>
</BaseLayout>
