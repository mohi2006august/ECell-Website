---
// Startup Glossary — 3D flip cards. Front shows the term, back the definition.
// Purely client-side (static content); flips on click/tap and keyboard.
interface Props { eyebrow?: string; title?: string; description?: string; }
const {
  eyebrow = 'Startup glossary',
  title = 'Founder-speak, decoded',
  description = 'The jargon you’ll hear around E-Cell — flip a card to learn what it actually means.',
} = Astro.props as Props;

const terms = [
  { term: 'MVP', full: 'Minimum Viable Product — the simplest version of your idea that real users can try, so you learn fast without building everything.' },
  { term: 'TAM', full: 'Total Addressable Market — the total revenue opportunity if everyone who could use your product actually did.' },
  { term: 'GTM', full: 'Go-To-Market — your plan for how you’ll reach customers and get them to actually use (and pay for) the product.' },
  { term: 'Runway', full: 'How many months you can keep operating before the money runs out, at your current burn rate.' },
  { term: 'Validation', full: 'Proof — from real users, not opinions — that people actually want and will pay for what you’re building.' },
  { term: 'Pivot', full: 'A deliberate change in direction — product, market, or model — while keeping what you’ve learned.' },
  { term: 'Burn Rate', full: 'How much cash you spend each month. “Burning ₹1L/mo” means you need that much to keep the lights on.' },
  { term: 'Traction', full: 'Evidence that your thing is working — growing users, revenue, or engagement over time.' },
];
---

<section id="glossary" class="container mx-auto px-6 py-14 md:py-20 relative z-10">
  <div class="max-w-2xl mb-8">
    <p class="font-pixel text-xs text-red-200/80 mb-4">{eyebrow}</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
  </div>

  <div class="gl-grid">
    {terms.map((t, i) => (
      <button type="button" class="gl-card" data-gl-card style={`--i:${i}`} aria-pressed="false">
        <span class="gl-inner">
          <span class="gl-face gl-front">
            <span class="gl-term font-jakarta">{t.term}</span>
            <span class="gl-hint font-pixel">Tap to flip</span>
          </span>
          <span class="gl-face gl-back">
            <span class="gl-def">{t.full}</span>
          </span>
        </span>
      </button>
    ))}
  </div>
</section>

<style>
  .gl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
  }

  .gl-card {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    height: 11rem;
    perspective: 1000px;
    cursor: pointer;
    text-align: left;
    animation: glIn 0.5s ease both;
    animation-delay: calc(var(--i) * 60ms);
  }
  .gl-inner {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    transition: transform 560ms cubic-bezier(0.2, 0.9, 0.2, 1);
    transform-style: preserve-3d;
  }
  .gl-card.is-flipped .gl-inner { transform: rotateY(180deg); }
  .gl-card:hover .gl-inner { transform: rotateY(180deg); }
  .gl-card.is-flipped:hover .gl-inner { transform: rotateY(0deg); }

  .gl-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(248, 113, 113, 0.2);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04), 0 16px 34px rgba(0, 0, 0, 0.35);
  }
  .gl-front {
    justify-content: space-between;
    background: linear-gradient(150deg, rgba(60, 12, 8, 0.6), rgba(12, 4, 3, 0.7));
  }
  .gl-term {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, #fca5a5, #ef4444, #fb923c);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .gl-hint {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(254, 202, 202, 0.55);
  }
  .gl-back {
    transform: rotateY(180deg);
    background: linear-gradient(150deg, rgba(127, 29, 29, 0.42), rgba(10, 3, 2, 0.82));
    align-items: flex-start;
    justify-content: center;
  }
  .gl-def {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgb(254 226 226);
  }

  @keyframes glIn {
    from { opacity: 0; transform: translateY(16px) scale(0.96); }
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gl-card { animation: none; }
    .gl-inner { transition: none; }
    .gl-card:hover .gl-inner { transform: none; }
    .gl-card.is-flipped:hover .gl-inner { transform: rotateY(180deg); }
  }
</style>

<script>
  (() => {
    document.querySelectorAll<HTMLButtonElement>('[data-gl-card]').forEach((card) => {
      card.addEventListener('click', () => {
        const flipped = card.classList.toggle('is-flipped');
        card.setAttribute('aria-pressed', String(flipped));
      });
    });
  })();
</script>
