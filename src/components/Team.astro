---
import teamData from '../../team.json';

const members = teamData.core.slice(0, 8);
---

<section id="team" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="lg:grid lg:grid-cols-[220px_minmax(0,1fr)] lg:gap-10">
    <div class="plane-lane" aria-hidden="true">
      <span class="plane-stop" data-plane-stop></span>
    </div>

    <div>
      <div class="max-w-3xl mb-10 lg:ml-auto lg:text-right">
        <p class="font-pixel text-xs text-red-200/80 mb-4">Core Leadership</p>
        <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">The leadership behind E-Cell VJIT</h2>
        <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">The students driving entrepreneurship programs, campus innovation, and community growth.</p>
      </div>

      <div class="team-card-deck" data-team-deck>
        {members.map((member, index) => (
          <figure class={`team-deck-card team-deck-card-${index + 1}`} style={`--i:${index}`}>
            <img src={member.image || '/images/team-placeholder.svg'} alt="" loading="lazy" />
          </figure>
        ))}
      </div>

      <div class="mt-8 flex lg:justify-end">
        <a href="/team" class="inline-flex items-center gap-2 text-sm font-inter glass rounded-md px-4 py-2 hover:bg-red-900/20 hover:border-red-500/30 text-gray-200 transition-all">
          View Full Team
          <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
        </a>
      </div>
    </div>
  </div>
  <slot />
</section>

<script is:inline>
  (() => {
    const deck = document.querySelector('[data-team-deck]');
    if (!(deck instanceof HTMLElement)) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      deck.classList.add('is-visible');
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        deck.classList.toggle('is-visible', entry.isIntersecting);
      },
      { threshold: 0.28 }
    );

    observer.observe(deck);
  })();
</script>

<style>
  .team-card-deck {
    position: relative;
    min-height: 430px;
    display: grid;
    place-items: center;
    perspective: 1200px;
  }

  .team-card-deck::before {
    content: '';
    position: absolute;
    width: min(88%, 760px);
    height: 58%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(248, 113, 113, 0.18), transparent 68%);
    filter: blur(28px);
    opacity: 0.8;
  }

  .team-deck-card {
    position: relative;
    overflow: hidden;
    margin: 0;
    width: clamp(128px, 12vw, 176px);
    height: clamp(176px, 16.5vw, 238px);
    border-radius: 1rem;
    border: 1px solid rgba(248, 113, 113, 0.22);
    background:
      linear-gradient(145deg, rgba(127, 29, 29, 0.28), rgba(255, 255, 255, 0.04)),
      rgba(8, 2, 2, 0.88);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 22px 56px rgba(0, 0, 0, 0.38);
    padding: 0.55rem;
    grid-area: 1 / 1;
    opacity: 0;
    transform:
      translate3d(0, 64px, calc(var(--i) * -18px))
      rotate(calc((var(--i) - 3.5) * -2deg))
      scale(0.92);
    transition:
      transform 760ms cubic-bezier(0.2, 0.9, 0.18, 1),
      opacity 420ms ease;
    transition-delay: calc(var(--i) * 70ms);
  }

  .team-card-deck.is-visible .team-deck-card {
    opacity: 1;
  }

  .team-card-deck.is-visible .team-deck-card-1 {
    transform: translate3d(-455px, 28px, 0) rotate(-10deg);
  }

  .team-card-deck.is-visible .team-deck-card-2 {
    transform: translate3d(-320px, -34px, 0) rotate(-6deg);
  }

  .team-card-deck.is-visible .team-deck-card-3 {
    transform: translate3d(-190px, 24px, 0) rotate(-3deg);
  }

  .team-card-deck.is-visible .team-deck-card-4 {
    transform: translate3d(-64px, -38px, 0) rotate(-1deg);
  }

  .team-card-deck.is-visible .team-deck-card-5 {
    transform: translate3d(64px, 24px, 0) rotate(1deg);
  }

  .team-card-deck.is-visible .team-deck-card-6 {
    transform: translate3d(190px, -36px, 0) rotate(4deg);
  }

  .team-card-deck.is-visible .team-deck-card-7 {
    transform: translate3d(320px, 26px, 0) rotate(7deg);
  }

  .team-card-deck.is-visible .team-deck-card-8 {
    transform: translate3d(455px, -26px, 0) rotate(10deg);
  }

  .team-deck-card::before,
  .team-deck-card::after {
    content: '';
    position: absolute;
    pointer-events: none;
    z-index: 2;
  }

  .team-deck-card::before {
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 18%),
      linear-gradient(180deg, transparent 88%, rgba(20, 4, 2, 0.14));
  }

  .team-deck-card::after {
    top: 0.65rem;
    left: 0.65rem;
    width: 1.2rem;
    height: 1.2rem;
    border-top: 1px solid rgba(254, 226, 226, 0.7);
    border-left: 1px solid rgba(254, 226, 226, 0.7);
  }

  .team-deck-card img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 0.7rem;
    background: rgba(0, 0, 0, 0.08);
    filter: saturate(1.08) contrast(1.02);
    transition: transform 220ms ease, filter 220ms ease;
  }

  .team-deck-card:hover {
    z-index: 5;
  }

  .team-deck-card:hover img {
    transform: scale(1.035);
    filter: saturate(1.16) contrast(1.05);
  }

  @media (max-width: 1280px) {
    .team-card-deck {
      min-height: 390px;
    }

    .team-card-deck.is-visible .team-deck-card-1 {
      transform: translate3d(-315px, 26px, 0) rotate(-9deg);
    }

    .team-card-deck.is-visible .team-deck-card-2 {
      transform: translate3d(-225px, -32px, 0) rotate(-6deg);
    }

    .team-card-deck.is-visible .team-deck-card-3 {
      transform: translate3d(-135px, 22px, 0) rotate(-3deg);
    }

    .team-card-deck.is-visible .team-deck-card-4 {
      transform: translate3d(-45px, -36px, 0) rotate(-1deg);
    }

    .team-card-deck.is-visible .team-deck-card-5 {
      transform: translate3d(45px, 22px, 0) rotate(1deg);
    }

    .team-card-deck.is-visible .team-deck-card-6 {
      transform: translate3d(135px, -32px, 0) rotate(4deg);
    }

    .team-card-deck.is-visible .team-deck-card-7 {
      transform: translate3d(225px, 24px, 0) rotate(7deg);
    }

    .team-card-deck.is-visible .team-deck-card-8 {
      transform: translate3d(315px, -24px, 0) rotate(9deg);
    }
  }

  @media (max-width: 640px) {
    .team-card-deck {
      min-height: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      place-items: stretch;
      gap: 0.75rem;
      perspective: none;
    }

    .team-deck-card,
    .team-card-deck.is-visible .team-deck-card {
      width: auto;
      height: 190px;
      grid-area: auto;
      transform: none;
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .team-deck-card,
    .team-deck-card img {
      transition: none;
    }

    .team-deck-card,
    .team-card-deck.is-visible .team-deck-card {
      opacity: 1;
    }
  }
</style>
