---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundShader from '../components/BackgroundShader.astro';
import Navbar from '../components/Navbar.astro';
import StickyWall from '../components/StickyWall.astro';
import RetroReel from '../components/RetroReel.astro';
---

<BaseLayout title="E-Cell VJIT | Interactions">
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 pt-14 md:pt-20 pb-2 relative z-10">
    <div class="max-w-3xl">
      <p class="font-pixel text-xs text-red-200/80 mb-4">Playground</p>
      <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-5">Interactions</h1>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">
        Little interactive corners of E-Cell — say hi, leave a memory, mess around. More coming soon.
      </p>
    </div>
  </section>

  <StickyWall />

  <section id="tv" class="container mx-auto px-6 py-14 md:py-20 relative z-10">
    <div class="max-w-2xl mb-8">
      <p class="font-pixel text-xs text-red-200/80 mb-4">Now playing</p>
      <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">E-Cell TV</h2>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">
        Memories and moments from E-Cell, on loop. Flip channels, turn it up, go fullscreen.
      </p>
    </div>
    <RetroReel />
  </section>
</BaseLayout>
