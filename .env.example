PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never prefix these with PUBLIC_, they must not reach the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
MAILEROO_API_KEY=
MAILEROO_FROM_ADDRESS=
MAILEROO_FROM_NAME=E-Cell VJIT

# bcrypt hash of the admin console password, base64-encoded (see comment in
# src/lib/adminAuth.js for why — raw $2b$... hashes get mangled by dotenv-expand)
ADMIN_PASSWORD_HASH_B64=
ADMIN_SESSION_SECRET=
