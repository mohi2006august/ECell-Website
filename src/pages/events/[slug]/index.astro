---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackgroundShader from '../../../components/BackgroundShader.astro';
import Navbar from '../../../components/Navbar.astro';
import { supabase } from '../../../lib/supabase.js';
import { getRegistrationStatus, getRegistrationStatusLabel } from '../../../lib/eventStatus.js';

export const prerender = false;

const { slug } = Astro.params;
const { data: event, error } = await supabase.from('events').select('*').eq('slug', slug).single();

if (error || !event) {
  console.error('Failed to load event:', error?.message ?? `No event found for slug ${slug}`);
  return Astro.redirect('/events');
}

const { count: registrationCount, error: countError } = await supabase
  .from('registrations')
  .select('id', { count: 'exact', head: true })
  .eq('event_id', event.id);

if (countError) {
  console.error('Failed to load registration count:', countError.message);
}

const formattedDate = new Date(event.date).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const registrationStatus = getRegistrationStatus(event, registrationCount ?? 0);
const deadlinePassed = registrationStatus.deadlinePassed;
const canRegister = registrationStatus.canRegister;

let countdownTarget: string | null = null;
let countdownLabel = '';
if (event.registration_deadline && !deadlinePassed) {
  countdownTarget = new Date(event.registration_deadline).toISOString();
  countdownLabel = 'Registration closes in';
} else {
  const eventDateTime = new Date(event.time ? `${event.date}T${event.time}` : event.date);
  if (!isNaN(eventDateTime.getTime()) && eventDateTime > new Date()) {
    countdownTarget = eventDateTime.toISOString();
    countdownLabel = 'Event starts in';
  }
}

function toDisplayList(value: unknown) {
  if (!Array.isArray(value)) return [];
  return value.map((item) =>
    typeof item === 'string' ? item : item?.name ?? JSON.stringify(item)
  );
}

let teamSizeLabel: string | null = null;
if (event.is_team_event) {
  const min = event.min_team_size;
  const max = event.max_team_size;
  if (min && max) {
    teamSizeLabel = min === max ? `${min} members` : `${min}-${max} members`;
  } else if (min) {
    teamSizeLabel = `${min}+ members`;
  } else if (max) {
    teamSizeLabel = `Up to ${max} members`;
  } else {
    teamSizeLabel = 'Team event';
  }
}

const speakers = toDisplayList(event.speakers);
const judges = toDisplayList(event.judges);
const winners = toDisplayList(event.winners);
const chiefGuest =
  event.chief_guest && typeof event.chief_guest === 'object'
    ? event.chief_guest.name ?? JSON.stringify(event.chief_guest)
    : event.chief_guest;
---

<BaseLayout title={`E-Cell VJIT | ${event.title}`}>
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 pt-8 relative z-10">
    <a href="/events" class="event-back-link glass">
      <iconify-icon icon="solar:arrow-left-linear" width="16" height="16"></iconify-icon>
      Back to Events
    </a>
  </section>

  <section class="container mx-auto px-6 py-10 md:py-14 relative z-10">
    <div class="event-detail-shell noise-overlay">
      <figure class="event-detail-poster">
        {event.poster_url ? (
          <img src={event.poster_url} alt={`${event.title} poster`} loading="eager" decoding="async" />
        ) : (
          <div class="event-poster-fallback">
            <span>Poster</span>
            <strong>{event.title}</strong>
          </div>
        )}
      </figure>

      <div class="event-detail-copy">
        <span class="events-ghost-label">{event.mode} / {event.event_type}</span>
        <h1>{event.title}</h1>
        <p>{event.short_description}</p>

        {countdownTarget && (
          <div class="event-countdown-block">
            <p>{countdownLabel}</p>
            <div id="countdown" data-target={countdownTarget} class="event-countdown-grid">
              <div class="countdown-box"><span data-unit="days">--</span><small>Days</small></div>
              <div class="countdown-box"><span data-unit="hours">--</span><small>Hours</small></div>
              <div class="countdown-box"><span data-unit="minutes">--</span><small>Minutes</small></div>
              <div class="countdown-box"><span data-unit="seconds">--</span><small>Seconds</small></div>
            </div>
          </div>
        )}

        <div class="event-detail-actions">
          {canRegister ? (
            <a href={`/events/${event.slug}/registration`} class="hero-action stroke-button stroke-button-strong">
              <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
              Register
            </a>
          ) : (
            <span class="event-closed-pill">
              {getRegistrationStatusLabel(registrationStatus)}
            </span>
          )}
          <a href="#details" id="know-more-link" class="hero-action stroke-button stroke-button-muted">
            <iconify-icon icon="solar:round-alt-arrow-down-linear" width="20" height="20"></iconify-icon>
            Know more
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="details" class="container mx-auto px-6 pb-16 md:pb-24 relative z-10 max-w-5xl">
    <div class="fire-line-divider mb-10" aria-hidden="true"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
      <div class="event-info-card glass noise-overlay p-5">
        <p class="event-info-kicker">Date &amp; Time</p>
        <p>{formattedDate}{event.time ? ` / ${event.time}` : ''}</p>
      </div>
      <div class="event-info-card glass noise-overlay p-5">
        <p class="event-info-kicker">Venue</p>
        <p>{event.venue}</p>
      </div>
      {event.is_paid && (
        <div class="event-info-card glass noise-overlay p-5">
          <p class="event-info-kicker">Price</p>
          <p>Rs. {event.price}</p>
        </div>
      )}
      {event.prize_pool && (
        <div class="event-info-card glass noise-overlay p-5">
          <p class="event-info-kicker">Prize Pool</p>
          <p>{event.prize_pool}</p>
        </div>
      )}
      {teamSizeLabel && (
        <div class="event-info-card glass noise-overlay p-5">
          <p class="event-info-kicker">Team Size</p>
          <p>{teamSizeLabel}</p>
        </div>
      )}
    </div>

    {event.long_description && (
      <div class="event-content-card mb-10">
        <h2>About this event</h2>
        <p>{event.long_description}</p>
      </div>
    )}

    {(event.requirements || event.prerequisites) && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        {event.requirements && (
          <div class="event-content-card">
            <h3>Requirements</h3>
            <p>{event.requirements}</p>
          </div>
        )}
        {event.prerequisites && (
          <div class="event-content-card">
            <h3>Prerequisites</h3>
            <p>{event.prerequisites}</p>
          </div>
        )}
      </div>
    )}

    {(speakers.length > 0 || judges.length > 0 || chiefGuest || winners.length > 0) && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {speakers.length > 0 && (
          <div class="event-content-card">
            <h3>Speakers</h3>
            <ul>{speakers.map((name) => <li>{name}</li>)}</ul>
          </div>
        )}
        {judges.length > 0 && (
          <div class="event-content-card">
            <h3>Judges</h3>
            <ul>{judges.map((name) => <li>{name}</li>)}</ul>
          </div>
        )}
        {chiefGuest && (
          <div class="event-content-card">
            <h3>Chief Guest</h3>
            <p>{chiefGuest}</p>
          </div>
        )}
        {winners.length > 0 && (
          <div class="event-content-card">
            <h3>Winners</h3>
            <ul>{winners.map((name) => <li>{name}</li>)}</ul>
          </div>
        )}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .event-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgb(229 231 235);
    border: 1px solid rgba(248, 113, 113, 0.18);
    clip-path: polygon(0.75rem 0, 100% 0, 100% calc(100% - 0.75rem), calc(100% - 0.75rem) 100%, 0 100%, 0 0.75rem);
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
  }

  .events-ghost-label {
    width: fit-content;
    padding: 0.28rem 0.58rem;
    font-family: var(--font-pixel);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.22);
    background: rgba(127, 29, 29, 0.14);
    clip-path: polygon(0.55rem 0, 100% 0, 100% calc(100% - 0.55rem), calc(100% - 0.55rem) 100%, 0 100%, 0 0.55rem);
  }

  .event-detail-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: stretch;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background:
      radial-gradient(circle at 80% 12%, rgba(248, 113, 113, 0.16), transparent 30%),
      linear-gradient(145deg, rgba(24, 5, 4, 0.82), rgba(8, 2, 2, 0.92));
    clip-path: polygon(1.35rem 0, 100% 0, 100% calc(100% - 1.35rem), calc(100% - 1.35rem) 100%, 0 100%, 0 1.35rem);
    padding: clamp(1rem, 3vw, 1.4rem);
  }

  .event-detail-poster {
    min-height: 18rem;
    overflow: hidden;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: rgba(255, 255, 255, 0.035);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
  }

  .event-detail-poster img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    display: block;
  }

  .event-poster-fallback {
    min-height: inherit;
    height: 100%;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 0.65rem;
    padding: 1.25rem;
    text-align: center;
    background:
      radial-gradient(circle at 50% 36%, rgba(248, 113, 113, 0.22), transparent 34%),
      linear-gradient(135deg, rgba(127, 29, 29, 0.48), rgba(7, 2, 2, 0.92));
  }

  .event-poster-fallback span {
    color: rgba(254, 202, 202, 0.75);
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .event-poster-fallback strong {
    max-width: 80%;
    color: white;
    font-size: clamp(1.3rem, 4vw, 2.4rem);
    line-height: 1.1;
  }

  .event-detail-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    padding: clamp(0.35rem, 3vw, 1.25rem);
  }

  .event-detail-copy h1 {
    margin-top: 1rem;
    color: white;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 7vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .event-detail-copy > p {
    max-width: 42rem;
    margin-top: 1.1rem;
    color: rgba(229, 231, 235, 0.82);
    font-size: clamp(0.96rem, 1.7vw, 1.12rem);
    line-height: 1.7;
  }

  .event-countdown-block {
    margin-top: 1.5rem;
  }

  .event-countdown-block > p,
  .event-info-kicker {
    margin-bottom: 0.85rem;
    color: rgba(254, 202, 202, 0.8);
    font-family: var(--font-pixel);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .event-countdown-grid,
  .event-detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .event-detail-actions {
    margin-top: 1.6rem;
  }

  .event-closed-pill {
    display: inline-flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    color: rgba(209, 213, 219, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.035);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
    padding: 0.8rem 1.45rem;
    font-family: var(--font-pixel);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .event-info-card,
  .event-content-card {
    border: 1px solid rgba(248, 113, 113, 0.18);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent 34%),
      rgba(10, 2, 2, 0.46);
    clip-path: polygon(0.85rem 0, 100% 0, 100% calc(100% - 0.85rem), calc(100% - 0.85rem) 100%, 0 100%, 0 0.85rem);
  }

  .event-info-card p:last-child {
    color: white;
  }

  .event-content-card {
    padding: 1.25rem;
  }

  .event-content-card h2,
  .event-content-card h3 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .event-content-card h2 {
    font-size: 1.6rem;
  }

  .event-content-card p,
  .event-content-card li {
    color: rgba(209, 213, 219, 0.86);
    line-height: 1.7;
    white-space: pre-line;
  }

  .countdown-box {
    min-width: 68px;
    padding: 0.9rem 0.75rem;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(165deg, rgba(127, 29, 29, 0.16), rgba(6, 2, 2, 0.36));
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .countdown-box span {
    font-size: 1.6rem;
    font-weight: 700;
    color: white;
    font-variant-numeric: tabular-nums;
  }

  .countdown-box small {
    color: rgb(254 202 202);
    font-family: var(--font-pixel);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-action {
    min-width: min(100%, 15rem);
  }

  @media (min-width: 900px) {
    .event-detail-shell {
      grid-template-columns: minmax(18rem, 0.7fr) minmax(0, 1fr);
    }
  }
</style>

<script>
  const countdownEl = document.getElementById('countdown');

  if (countdownEl instanceof HTMLElement && countdownEl.dataset.target) {
    const target = new Date(countdownEl.dataset.target).getTime();
    const daysEl = countdownEl.querySelector('[data-unit="days"]');
    const hoursEl = countdownEl.querySelector('[data-unit="hours"]');
    const minutesEl = countdownEl.querySelector('[data-unit="minutes"]');
    const secondsEl = countdownEl.querySelector('[data-unit="seconds"]');

    let intervalId: ReturnType<typeof setInterval>;

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        countdownEl.textContent = "It's here!";
        clearInterval(intervalId);
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);

      if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
    };

    tick();
    intervalId = setInterval(tick, 1000);
  }

  document.getElementById('know-more-link')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('details')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
