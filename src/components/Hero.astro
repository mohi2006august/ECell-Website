---
interface Props {
  title?: string;
  description?: string;
  primaryAction?: string;
  secondaryAction?: string;
  primaryHref?: string;
  secondaryHref?: string;
}

const {
  title = 'E-CELL VJIT',
  description = 'E-Cell brings together students who want to learn, build, and experiment with real-world problems. Through events, mentorship, and a strong community, it creates opportunities to move from curiosity to execution.',
  primaryAction = 'View Upcoming Events',
  secondaryAction = 'Register for Events',
  primaryHref = '/events',
  secondaryHref = '/events#register',
} = Astro.props as Props;
---

<div id="home" class="relative overflow-hidden">
  <div class="hero-shell container mx-auto px-6 py-12 md:py-14 relative z-10">
    <div class="hero-grid flex flex-col items-center text-center">
      <div class="hero-intro max-w-5xl w-full">
        <div class="hero-typewriter" aria-label="E-Cell kinetic tagline">
          <span class="hero-typewriter-dot" aria-hidden="true"></span>
          <span class="hero-typewriter-text" data-hero-typewriter>we build</span>
          <span class="hero-typewriter-caret" aria-hidden="true"></span>
        </div>

        <h1 class="sr-only">{title}</h1>

        <div class="hero-title-stage" data-hero-hover>
          <svg width="100%" height="100%" viewBox="0 0 1600 360" xmlns="http://www.w3.org/2000/svg" class="hero-title-svg" role="img" aria-label={title}>
            <defs>
              <linearGradient id="heroTextGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fb7185" />
                <stop offset="50%" stop-color="#ef4444" />
                <stop offset="100%" stop-color="#fb923c" />
              </linearGradient>
            </defs>

            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-outline">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-stroke">{title}</text>
          </svg>
        </div>

        <p class="hero-copy text-gray-300 text-lg md:text-xl mt-1 mb-6 max-w-3xl mx-auto font-inter font-light tracking-normal leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-col sm:flex-row gap-4 justify-center">
          <a href={primaryHref} class="hero-action stroke-button stroke-button-strong">
            <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
            {primaryAction}
          </a>
          <a href={secondaryHref} class="hero-action stroke-button stroke-button-muted">
            <iconify-icon icon="solar:play-circle-linear" width="20" height="20"></iconify-icon>
            {secondaryAction}
          </a>
        </div>
      </div>
    </div>

    <div class="hero-divider h-px glass-divider mt-10 opacity-50"></div>
  </div>
</div>

<script is:inline>
  (() => {
    const target = document.querySelector('[data-hero-typewriter]');
    if (!(target instanceof HTMLElement)) return;

    const phrases = ['we build', 'we pitch', 'we launch', 'we fail forward'];
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      target.textContent = phrases.join('  ▸  ');
      return;
    }

    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      const phrase = phrases[phraseIndex];
      target.textContent = phrase.slice(0, charIndex);

      if (!deleting && charIndex < phrase.length) {
        charIndex += 1;
        window.setTimeout(tick, 58);
        return;
      }

      if (!deleting && charIndex === phrase.length) {
        deleting = true;
        window.setTimeout(tick, 1050);
        return;
      }

      if (deleting && charIndex > 0) {
        charIndex -= 1;
        window.setTimeout(tick, 34);
        return;
      }

      deleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      window.setTimeout(tick, 220);
    };

    tick();
  })();
</script>

<style>
  .hero-shell {
    min-height: calc(100vh - 7.5rem);
    display: flex;
    align-items: center;
    padding-top: 0;
    padding-bottom: 5rem;
  }

  .hero-grid {
    width: 100%;
  }

  .hero-typewriter {
    width: fit-content;
    min-width: 0;
    min-height: 2.15rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-bottom: 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(248, 113, 113, 0.28);
    background: rgba(127, 29, 29, 0.22);
    color: rgb(254, 226, 226);
    box-shadow: 0 0 18px rgba(248, 113, 113, 0.1);
    padding: 0.34rem 0.8rem;
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-typewriter-dot {
    width: 0.45rem;
    height: 0.45rem;
    flex: 0 0 auto;
    border-radius: 999px;
    background: rgb(239, 68, 68);
    box-shadow: 0 0 12px rgba(239, 68, 68, 0.78);
  }

  .hero-typewriter-text {
    min-width: 0;
    text-align: center;
  }

  .hero-typewriter-caret {
    width: 0.46rem;
    height: 1rem;
    flex: 0 0 auto;
    background: rgb(254, 226, 226);
    box-shadow: 0 0 12px rgba(254, 226, 226, 0.55);
    animation: heroCaretBlink 780ms steps(2, end) infinite;
  }

  .hero-title-stage {
    width: min(100%, 1600px);
    margin: 0 auto;
    height: clamp(128px, 20vw, 260px);
    position: relative;
  }

  .hero-title-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-hover-outline,
  .hero-hover-stroke {
    font-family: 'Notable', 'Climate Crisis', 'Prosto One', sans-serif;
    font-size: clamp(96px, 12.2vw, 160px);
    font-weight: 400;
    fill: transparent;
    letter-spacing: 0;
    paint-order: stroke fill;
  }

  .hero-hover-outline {
    stroke: rgba(255, 240, 240, 0.52);
    stroke-width: 0.8;
  }

  .hero-hover-stroke {
    stroke: rgba(255, 145, 132, 1);
    stroke-width: 1.2;
    stroke-dasharray: 950;
    stroke-dashoffset: 950;
    filter: drop-shadow(0 0 16px rgba(255, 92, 82, 0.5));
  }

  .hero-copy {
    text-wrap: balance;
  }

  .hero-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .hero-action {
    min-width: min(100%, 17rem);
  }

  body:not(.loading) .hero-hover-stroke {
    animation: heroStrokeIgnite 4.8s ease-in-out infinite;
  }

  body.loading .hero-hover-stroke {
    animation: none;
    stroke-dashoffset: 950;
    opacity: 0.18;
  }

  @keyframes heroStrokeIgnite {
    0%,
    14% {
      stroke-dashoffset: 950;
      opacity: 0.18;
    }
    38%,
    78% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 950;
      opacity: 0.18;
    }
  }

  @keyframes heroCaretBlink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .hero-shell {
      min-height: calc(100vh - 5rem);
      padding-top: 1.25rem;
      padding-bottom: 3rem;
    }

    .hero-title-stage {
      height: clamp(118px, 31vw, 205px);
    }
  }
</style>
