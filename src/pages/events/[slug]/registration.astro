---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackgroundShader from '../../../components/BackgroundShader.astro';
import Navbar from '../../../components/Navbar.astro';
import { supabase } from '../../../lib/supabase.js';

export async function getStaticPaths() {
  const { data: events, error } = await supabase.from('events').select('*');

  if (error) {
    console.error('Failed to load events for static paths:', error.message);
    return [];
  }

  return (events ?? []).map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

const formattedDate = new Date(event.date).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const deadlinePassed =
  event.registration_deadline && new Date(event.registration_deadline) < new Date();
const canRegister = event.registration_open && !deadlinePassed;

const isTeamEvent = Boolean(event.is_team_event);
const minTeamSize: number | null = event.min_team_size ?? null;
const maxTeamSize: number | null = event.max_team_size ?? null;

let teamSizeText = "Add your teammates below — each person gets their own ticket and QR code.";
if (minTeamSize && maxTeamSize) {
  teamSizeText =
    minTeamSize === maxTeamSize
      ? `Teams must have exactly ${minTeamSize} members (including you).`
      : `Teams must have ${minTeamSize}–${maxTeamSize} members (including you).`;
} else if (minTeamSize) {
  teamSizeText = `Teams must have at least ${minTeamSize} members (including you).`;
} else if (maxTeamSize) {
  teamSizeText = `Teams can have up to ${maxTeamSize} members (including you).`;
}

const defaultTeammateCount = isTeamEvent
  ? Math.min(
      Math.max((minTeamSize ?? 2) - 1, 0),
      maxTeamSize ? Math.max(maxTeamSize - 1, 0) : Infinity
    )
  : 0;

const memberFields = [
  { field: 'name', type: 'text', placeholder: 'Full name' },
  { field: 'email', type: 'email', placeholder: 'Email' },
  { field: 'phone', type: 'tel', placeholder: 'Phone number' },
  { field: 'roll_number', type: 'text', placeholder: 'Roll number' },
];

const registrationSteps = isTeamEvent ? ['Details', 'Team', 'Confirm'] : ['Details', 'Confirm'];
---

<BaseLayout title={`E-Cell VJIT | Register for ${event.title}`}>
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 py-12 md:py-16 relative z-10 max-w-5xl">
    <a
      href={`/events/${event.slug}`}
      class="event-back-link inline-flex items-center gap-2 glass px-4 py-2 text-sm font-inter text-gray-200 hover:text-white hover:border-red-500/30 transition-all mb-8"
    >
      <iconify-icon icon="solar:arrow-left-linear" width="16" height="16"></iconify-icon>
      Back to {event.title}
    </a>

    <div class="mb-8">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-3">Register</p>
      <h1 class="text-3xl md:text-4xl font-jakarta font-semibold tracking-tight mb-3">{event.title}</h1>
      <p class="text-gray-400 font-inter text-sm">
        {formattedDate}{event.time ? ` · ${event.time}` : ''} · {event.venue}
      </p>
    </div>

    <div class="registration-shell noise-overlay p-5 md:p-8">
      {!canRegister && (
        <p class="registration-closed-copy">
          {deadlinePassed ? 'Registration has closed for this event.' : "Registration isn't open yet."}
        </p>
      )}

      {canRegister && (
        <form
          id="registration-form"
          class="flex flex-col gap-7"
          data-event-id={event.id}
          data-event-slug={event.slug}
          data-is-team-event={String(isTeamEvent)}
          data-min-team-size={isTeamEvent && minTeamSize ? minTeamSize : ''}
          data-max-team-size={isTeamEvent && maxTeamSize ? maxTeamSize : ''}
        >
          <div class="stepper-shell" aria-label="Registration progress">
            {registrationSteps.map((step, index) => (
              <div class="stepper-item" data-step-indicator={index}>
                <span>{index + 1}</span>
                <p>{step}</p>
              </div>
            ))}
          </div>

          <section class="form-step is-active" data-step-panel="0">
            <div class="step-card-heading">
              <p class="font-pixel">Step 01</p>
              <h2>Your details</h2>
            </div>
            <div class="detail-card-grid">
              <div class="detail-input-card">
                <div class="detail-input-card-head">
                  <span>
                    <iconify-icon icon="solar:user-rounded-linear" width="20" height="20"></iconify-icon>
                  </span>
                  <div>
                    <p class="font-pixel">Personal</p>
                    <h3>Contact details</h3>
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input type="text" name="name" placeholder="Full name" required class="reg-input" />
                  <input type="email" name="email" placeholder="Email" required class="reg-input" />
                  <input type="tel" name="phone" placeholder="Phone number" class="reg-input sm:col-span-2" />
                </div>
              </div>

              <div class="detail-input-card">
                <div class="detail-input-card-head">
                  <span>
                    <iconify-icon icon="solar:buildings-2-linear" width="20" height="20"></iconify-icon>
                  </span>
                  <div>
                    <p class="font-pixel">College</p>
                    <h3>Academic details</h3>
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input type="text" name="roll_number" placeholder="Roll number" class="reg-input" />
                  <div class="field-with-other">
                    <select name="branch" class="reg-input" data-other-select data-other-target="branch_other" required>
                      <option value="">Branch</option>
                      <option value="CSE">CSE</option>
                      <option value="IT">IT</option>
                      <option value="CSE AIML">CSE AIML</option>
                      <option value="CSE DS">CSE DS</option>
                      <option value="Mechanical">Mechanical</option>
                      <option value="Civil">Civil</option>
                      <option value="ECE">ECE</option>
                      <option value="EEE">EEE</option>
                      <option value="Other">Other</option>
                    </select>
                    <input type="text" name="branch_other" placeholder="Type branch" class="reg-input other-input hidden" />
                  </div>
                  <select name="year_of_study" class="reg-input">
                    <option value="">Year</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                  </select>
                  <select name="section" class="reg-input">
                    <option value="">Section</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                  </select>
                  <div class="field-with-other sm:col-span-2">
                    <select name="college" class="reg-input" data-other-select data-other-target="college_other">
                      <option value="VJIT">VJIT</option>
                      <option value="Other">Other</option>
                    </select>
                    <input type="text" name="college_other" placeholder="Type college name" class="reg-input other-input hidden" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          {isTeamEvent && (
            <section class="form-step" data-step-panel="1">
              <div class="step-card-heading">
                <p class="font-pixel">Step 02</p>
                <h2>Team</h2>
              </div>
              <p class="text-gray-400 font-inter text-sm mb-5">{teamSizeText}</p>
              <input type="text" name="team_name" placeholder="Team name" required class="reg-input w-full mb-4" />

              <div id="team-members-list" class="space-y-4">
                {Array.from({ length: defaultTeammateCount }).map(() => (
                  <div class="team-member-block glass noise-overlay p-4 relative">
                    <button type="button" class="remove-member-btn" aria-label="Remove teammate">&minus;</button>
                    <label class="flex items-center gap-2 text-xs text-gray-400 font-inter mb-3">
                      <input type="checkbox" class="same-as-me-checkbox" />
                      Same as me (year, branch, section, college)
                    </label>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      {memberFields.map(({ field, type, placeholder }) => (
                        <input type={type} data-field={field} placeholder={placeholder} class="reg-input" />
                      ))}
                      <div class="field-with-other">
                        <select data-field="branch" class="reg-input" data-other-select data-other-target="member_branch_other">
                          <option value="">Branch</option>
                          <option value="CSE">CSE</option>
                          <option value="IT">IT</option>
                          <option value="CSE AIML">CSE AIML</option>
                          <option value="CSE DS">CSE DS</option>
                          <option value="Mechanical">Mechanical</option>
                          <option value="Civil">Civil</option>
                          <option value="ECE">ECE</option>
                          <option value="EEE">EEE</option>
                          <option value="Other">Other</option>
                        </select>
                        <input type="text" data-field="branch_other" placeholder="Type branch" class="reg-input other-input hidden" />
                      </div>
                      <select data-field="year_of_study" class="reg-input">
                        <option value="">Year</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                      </select>
                      <select data-field="section" class="reg-input">
                        <option value="">Section</option>
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                      </select>
                      <div class="field-with-other">
                        <select data-field="college" class="reg-input" data-other-select data-other-target="member_college_other">
                          <option value="VJIT">VJIT</option>
                          <option value="Other">Other</option>
                        </select>
                        <input type="text" data-field="college_other" placeholder="Type college name" class="reg-input other-input hidden" />
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <div class="flex items-center gap-4 mt-4">
                <button type="button" id="add-member-btn" class="add-member-btn">
                  + Add teammate
                </button>
                <span id="team-count-text" class="text-xs text-gray-400 font-inter"></span>
              </div>
            </section>
          )}

          <section class="form-step" data-step-panel={isTeamEvent ? '2' : '1'}>
            <div class="step-card-heading">
              <p class="font-pixel">{isTeamEvent ? 'Step 03' : 'Step 02'}</p>
              <h2>Confirm</h2>
            </div>
            <div class="confirm-pass-preview">
              <div class="confirm-pass-head">
                <div>
                  <p class="font-pixel">Ready to issue</p>
                  <h3>{event.title}</h3>
                  <span>{formattedDate}{event.time ? ` · ${event.time}` : ''}</span>
                </div>
                <iconify-icon icon="solar:ticket-sale-linear" width="54" height="54"></iconify-icon>
              </div>
              <div id="review-panel" class="review-panel confirm-review-panel"></div>
            </div>
            <div class="confirm-note-card">
              <iconify-icon icon="solar:qr-code-linear" width="18" height="18"></iconify-icon>
              <p>Once confirmed, individual QR tickets will be generated for every registered attendee.</p>
            </div>
          </section>

          <div class="step-actions">
            <button type="button" id="step-back-btn" class="step-btn step-btn-ghost">Back</button>
            <button type="button" id="step-next-btn" class="step-btn step-btn-primary">Next</button>
            <button type="submit" id="confirm-submit-btn" class="step-btn step-btn-primary hidden">Confirm registration</button>
          </div>

          <p id="registration-status" class="text-sm font-inter" role="status"></p>
        </form>
      )}
    </div>
  </section>
</BaseLayout>

<template id="member-block-template">
  <div class="team-member-block glass noise-overlay p-4 relative">
    <button type="button" class="remove-member-btn" aria-label="Remove teammate">&minus;</button>
    <label class="flex items-center gap-2 text-xs text-gray-400 font-inter mb-3">
      <input type="checkbox" class="same-as-me-checkbox" />
      Same as me (year, branch, section, college)
    </label>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {memberFields.map(({ field, type, placeholder }) => (
        <input type={type} data-field={field} placeholder={placeholder} class="reg-input" />
      ))}
      <div class="field-with-other">
        <select data-field="branch" class="reg-input" data-other-select data-other-target="member_branch_other">
          <option value="">Branch</option>
          <option value="CSE">CSE</option>
          <option value="IT">IT</option>
          <option value="CSE AIML">CSE AIML</option>
          <option value="CSE DS">CSE DS</option>
          <option value="Mechanical">Mechanical</option>
          <option value="Civil">Civil</option>
          <option value="ECE">ECE</option>
          <option value="EEE">EEE</option>
          <option value="Other">Other</option>
        </select>
        <input type="text" data-field="branch_other" placeholder="Type branch" class="reg-input other-input hidden" />
      </div>
      <select data-field="year_of_study" class="reg-input">
        <option value="">Year</option>
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
      </select>
      <select data-field="section" class="reg-input">
        <option value="">Section</option>
        <option value="A">A</option>
        <option value="B">B</option>
        <option value="C">C</option>
        <option value="D">D</option>
      </select>
      <div class="field-with-other">
        <select data-field="college" class="reg-input" data-other-select data-other-target="member_college_other">
          <option value="VJIT">VJIT</option>
          <option value="Other">Other</option>
        </select>
        <input type="text" data-field="college_other" placeholder="Type college name" class="reg-input other-input hidden" />
      </div>
    </div>
  </div>
</template>

<style>
  .registration-shell {
    border: 1px solid rgba(248, 113, 113, 0.18);
    background:
      radial-gradient(circle at 78% 12%, rgba(248, 113, 113, 0.16), transparent 32%),
      linear-gradient(145deg, rgba(24, 5, 4, 0.82), rgba(8, 2, 2, 0.92));
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
    clip-path: polygon(1.35rem 0, 100% 0, 100% calc(100% - 1.35rem), calc(100% - 1.35rem) 100%, 0 100%, 0 1.35rem);
  }

  .event-back-link,
  .registration-closed-copy {
    clip-path: polygon(0.8rem 0, 100% 0, 100% calc(100% - 0.8rem), calc(100% - 0.8rem) 100%, 0 100%, 0 0.8rem);
  }

  .registration-closed-copy {
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: rgba(255, 255, 255, 0.035);
    padding: 1rem;
    color: rgb(209 213 219);
    font-family: 'Prosto One', system-ui, sans-serif;
  }

  .stepper-shell {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.65rem;
    padding: 0.45rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.26);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
  }

  .stepper-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    padding: 0.7rem;
    color: rgb(156, 163, 175);
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .stepper-item span {
    width: 1.75rem;
    height: 1.75rem;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.12);
    clip-path: polygon(0.45rem 0, 100% 0, 100% calc(100% - 0.45rem), calc(100% - 0.45rem) 100%, 0 100%, 0 0.45rem);
    font-family: 'Pixelify Sans', ui-monospace, monospace;
  }

  .stepper-item p {
    overflow: hidden;
    margin: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stepper-item.is-active {
    color: white;
    background: linear-gradient(135deg, rgba(185, 28, 28, 0.48), rgba(249, 115, 22, 0.18));
  }

  .stepper-item.is-complete {
    color: rgb(254, 202, 202);
  }

  .stepper-item.is-complete span {
    border-color: rgba(248, 113, 113, 0.5);
    background: rgba(127, 29, 29, 0.22);
  }

  .form-step {
    display: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem;
    background: rgba(0, 0, 0, 0.22);
    clip-path: polygon(1rem 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%, 0 1rem);
  }

  .form-step.is-active {
    display: block;
    animation: stepIn 260ms ease-out;
  }

  .step-card-heading {
    margin-bottom: 1rem;
  }

  .step-card-heading p {
    margin-bottom: 0.4rem;
    color: rgb(254, 202, 202);
    font-size: 0.68rem;
  }

  .step-card-heading h2 {
    color: white;
    font-size: clamp(1.4rem, 3vw, 2.35rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .reg-input {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1rem;
    color: white;
    font-family: 'Prosto One', system-ui, sans-serif;
    width: 100%;
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
  }

  select.reg-input {
    appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, rgba(254, 202, 202, 0.8) 50%),
      linear-gradient(135deg, rgba(254, 202, 202, 0.8) 50%, transparent 50%);
    background-position:
      calc(100% - 18px) 50%,
      calc(100% - 12px) 50%;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 2.4rem;
  }

  select.reg-input option {
    background: rgb(20, 4, 3);
    color: white;
  }

  .field-with-other {
    display: grid;
    gap: 0.65rem;
  }

  .reg-input:focus {
    outline: none;
    border-color: rgba(248, 113, 113, 0.5);
  }

  .detail-card-grid {
    display: grid;
    gap: 1rem;
  }

  .detail-input-card {
    border: 1px solid rgba(248, 113, 113, 0.16);
    padding: 1rem;
    background:
      linear-gradient(135deg, rgba(127, 29, 29, 0.18), rgba(255, 255, 255, 0.025)),
      rgba(0, 0, 0, 0.16);
    clip-path: polygon(0.95rem 0, 100% 0, 100% calc(100% - 0.95rem), calc(100% - 0.95rem) 100%, 0 100%, 0 0.95rem);
  }

  .detail-input-card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .detail-input-card-head > span {
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    color: rgb(254, 202, 202);
    border: 1px solid rgba(248, 113, 113, 0.24);
    background: rgba(127, 29, 29, 0.18);
    clip-path: polygon(0.6rem 0, 100% 0, 100% calc(100% - 0.6rem), calc(100% - 0.6rem) 100%, 0 100%, 0 0.6rem);
  }

  .detail-input-card-head p {
    margin: 0 0 0.15rem;
    color: rgb(254, 202, 202);
    font-size: 0.65rem;
  }

  .detail-input-card-head h3 {
    margin: 0;
    color: white;
    font-size: 1.05rem;
    letter-spacing: 0;
  }

  .team-member-block {
    border: 1px solid rgba(255, 255, 255, 0.08);
    clip-path: polygon(0.9rem 0, 100% 0, 100% calc(100% - 0.9rem), calc(100% - 0.9rem) 100%, 0 100%, 0 0.9rem);
  }

  .remove-member-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid rgba(248, 113, 113, 0.3);
    background: rgba(127, 29, 29, 0.2);
    color: rgb(254 202 202);
    font-size: 0.9rem;
    line-height: 1;
    display: grid;
    place-items: center;
    cursor: pointer;
    clip-path: polygon(0.4rem 0, 100% 0, 100% calc(100% - 0.4rem), calc(100% - 0.4rem) 100%, 0 100%, 0 0.4rem);
  }

  .remove-member-btn:hover {
    background: rgba(127, 29, 29, 0.4);
  }

  .add-member-btn {
    border: 1px dashed rgba(248, 113, 113, 0.35);
    padding: 0.6rem 1.1rem;
    color: rgb(254 202 202);
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.9rem;
    background: transparent;
    cursor: pointer;
    transition: background-color 150ms ease;
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
  }

  .add-member-btn:hover:not(:disabled) {
    background: rgba(127, 29, 29, 0.14);
  }

  .add-member-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .confirm-pass-preview {
    border: 1px solid rgba(248, 113, 113, 0.2);
    padding: 1rem;
    background:
      linear-gradient(135deg, rgba(127, 29, 29, 0.3), rgba(255, 255, 255, 0.04)),
      rgba(0, 0, 0, 0.24);
    clip-path: polygon(0.95rem 0, 100% 0, 100% calc(100% - 0.95rem), calc(100% - 0.95rem) 100%, 0 100%, 0 0.95rem);
  }

  .confirm-pass-preview iconify-icon {
    color: rgb(254, 202, 202);
    filter: drop-shadow(0 0 14px rgba(248, 113, 113, 0.35));
  }

  .confirm-pass-preview h3 {
    color: white;
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .confirm-pass-preview span {
    color: rgb(209, 213, 219);
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.9rem;
  }

  .confirm-pass-preview {
    margin-bottom: 1rem;
    display: grid;
    align-items: stretch;
  }

  .confirm-pass-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding: 1rem;
    border: 1px solid rgba(248, 113, 113, 0.16);
    background:
      radial-gradient(circle at 100% 0%, rgba(248, 113, 113, 0.16), transparent 38%),
      rgba(0, 0, 0, 0.18);
    clip-path: polygon(0.8rem 0, 100% 0, 100% calc(100% - 0.8rem), calc(100% - 0.8rem) 100%, 0 100%, 0 0.8rem);
  }

  .confirm-pass-head p {
    margin-bottom: 0.45rem;
    color: rgb(254, 202, 202);
    font-size: 0.68rem;
  }

  .review-panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    align-items: start;
  }

  .review-card {
    border: 1px solid rgba(248, 113, 113, 0.16);
    padding: 0.85rem;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02)),
      rgba(0, 0, 0, 0.2);
    clip-path: polygon(0.85rem 0, 100% 0, 100% calc(100% - 0.85rem), calc(100% - 0.85rem) 100%, 0 100%, 0 0.85rem);
  }

  .review-card-team {
    grid-column: 1 / -1;
  }

  .review-card.review-card-primary {
    background:
      radial-gradient(circle at 100% 0%, rgba(248, 113, 113, 0.12), transparent 42%),
      rgba(255, 255, 255, 0.045);
  }

  .review-card-heading {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
  }

  .review-card-heading > span {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    flex: 0 0 auto;
    color: rgb(254, 202, 202);
    background: rgba(127, 29, 29, 0.28);
    box-shadow: inset 0 0 0 1px rgba(248, 113, 113, 0.28);
    clip-path: polygon(0.55rem 0, 100% 0, 100% calc(100% - 0.55rem), calc(100% - 0.55rem) 100%, 0 100%, 0 0.55rem);
  }

  .review-card-heading p,
  .teammate-review-card > p {
    margin: 0 0 0.18rem;
    color: rgb(252, 165, 165);
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .review-card-heading h3 {
    color: white;
    font-size: 0.92rem;
    margin: 0;
  }

  .review-card-subtitle {
    margin: 0 0 0.9rem;
    color: rgb(156, 163, 175);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .review-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .review-field {
    margin: 0;
    min-width: 0;
    padding: 0.62rem 0.68rem;
    background: rgba(0, 0, 0, 0.24);
    border: 1px solid rgba(255, 255, 255, 0.07);
    clip-path: polygon(0.55rem 0, 100% 0, 100% calc(100% - 0.55rem), calc(100% - 0.55rem) 100%, 0 100%, 0 0.55rem);
  }

  .review-field span {
    display: block;
    margin-bottom: 0.25rem;
    color: rgb(156, 163, 175);
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .review-field strong {
    display: block;
    color: rgb(243, 244, 246);
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: none;
    overflow-wrap: anywhere;
  }

  .review-card-team {
    background:
      radial-gradient(circle at 100% 0%, rgba(249, 115, 22, 0.12), transparent 42%),
      rgba(255, 255, 255, 0.035);
  }

  .teammate-review-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .teammate-review-card {
    padding: 0.85rem;
    border: 1px solid rgba(248, 113, 113, 0.12);
    background: rgba(0, 0, 0, 0.16);
    clip-path: polygon(0.7rem 0, 100% 0, 100% calc(100% - 0.7rem), calc(100% - 0.7rem) 100%, 0 100%, 0 0.7rem);
  }

  .confirm-note-card {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: fit-content;
    max-width: 100%;
    margin-top: 0.75rem;
    padding: 0.72rem 0.9rem;
    color: rgb(209, 213, 219);
    border: 1px solid rgba(248, 113, 113, 0.14);
    background: rgba(0, 0, 0, 0.2);
    clip-path: polygon(0.65rem 0, 100% 0, 100% calc(100% - 0.65rem), calc(100% - 0.65rem) 100%, 0 100%, 0 0.65rem);
  }

  .confirm-note-card iconify-icon {
    color: rgb(254, 202, 202);
    flex: 0 0 auto;
  }

  .confirm-note-card p {
    margin: 0;
    font-family: 'Prosto One', system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .step-actions {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .step-btn {
    min-height: 3rem;
    padding: 0.75rem 1.35rem;
    font-family: 'Pixelify Sans', ui-monospace, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 160ms ease, background-color 160ms ease, opacity 160ms ease, filter 160ms ease;
  }

  .step-btn:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .step-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .step-btn-primary {
    color: rgb(254, 226, 226);
    border: 0;
    background: rgba(10, 2, 2, 0.2);
    clip-path: polygon(0.82rem 0, 100% 0, 100% calc(100% - 0.82rem), calc(100% - 0.82rem) 100%, 0 100%, 0 0.82rem);
    box-shadow: inset 0 0 0 1.4px rgba(254, 202, 202, 0.58);
    position: relative;
    overflow: hidden;
  }

  .step-btn-primary:hover:not(:disabled) {
    color: white;
    background: rgba(127, 29, 29, 0.58);
    filter: drop-shadow(0 0 16px rgba(248, 113, 113, 0.24));
  }

  .step-btn-ghost {
    color: rgb(254, 226, 226);
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(255, 255, 255, 0.035);
  }

  @keyframes stepIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {
    .stepper-shell {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .review-panel,
    .teammate-review-grid {
      grid-template-columns: 1fr;
    }

    .review-list {
      grid-template-columns: 1fr;
    }

    .step-actions {
      flex-direction: column-reverse;
    }
  }
</style>

<script>
  import { supabase } from '../../../lib/supabase.js';

  const form = document.getElementById('registration-form');
  const status = document.getElementById('registration-status');
  const teamMembersList = document.getElementById('team-members-list');
  const addMemberBtn = document.getElementById('add-member-btn');
  const memberTemplate = document.getElementById('member-block-template');
  const teamCountText = document.getElementById('team-count-text');
  const stepPanels = Array.from(document.querySelectorAll<HTMLElement>('[data-step-panel]'));
  const stepIndicators = Array.from(document.querySelectorAll<HTMLElement>('[data-step-indicator]'));
  const backBtn = document.getElementById('step-back-btn');
  const nextBtn = document.getElementById('step-next-btn');
  const confirmBtn = document.getElementById('confirm-submit-btn');
  const reviewPanel = document.getElementById('review-panel');

  const SAME_AS_ME_FIELDS = ['year_of_study', 'branch', 'section', 'college'];
  const isTeamEvent = form instanceof HTMLFormElement && form.dataset.isTeamEvent === 'true';
  let currentStep = 0;
  const maxStep = Math.max(0, stepPanels.length - 1);

  const minTeamSize = form instanceof HTMLFormElement && form.dataset.minTeamSize
    ? parseInt(form.dataset.minTeamSize, 10)
    : null;
  const maxTeamSize = form instanceof HTMLFormElement && form.dataset.maxTeamSize
    ? parseInt(form.dataset.maxTeamSize, 10)
    : null;

  function currentMemberCount() {
    return 1 + (teamMembersList?.querySelectorAll('.team-member-block').length ?? 0);
  }

  function setStatus(message = '', isError = false) {
    if (!status) return;
    status.textContent = message;
    status.classList.toggle('text-red-300', isError);
  }

  function getFormValue(field: string) {
    if (!(form instanceof HTMLFormElement)) return '';
    const value = form.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${field}"]`)?.value.trim() ?? '';
    if (value === 'Other') {
      return form.querySelector<HTMLInputElement>(`[name="${field}_other"]`)?.value.trim() ?? '';
    }
    return value;
  }

  function getBlockValue(block: Element, field: string) {
    const value = block.querySelector<HTMLInputElement | HTMLSelectElement>(`[data-field="${field}"]`)?.value.trim() || '';
    if (value === 'Other') {
      return block.querySelector<HTMLInputElement>(`[data-field="${field}_other"]`)?.value.trim() || '';
    }
    return value;
  }

  function collectTeammates() {
    return Array.from(document.querySelectorAll('#team-members-list .team-member-block'))
      .map((block) => {
        return {
          name: getBlockValue(block, 'name'),
          email: getBlockValue(block, 'email'),
          phone: getBlockValue(block, 'phone') || null,
          roll_number: getBlockValue(block, 'roll_number') || null,
          branch: getBlockValue(block, 'branch') || null,
          year_of_study: getBlockValue(block, 'year_of_study') || null,
          section: getBlockValue(block, 'section') || null,
          college: getBlockValue(block, 'college') || null,
        };
      })
      .filter((member) => member.name && member.email);
  }

  function validateStep(step: number) {
    if (!(form instanceof HTMLFormElement)) return false;

    if (step === 0) {
      for (const field of ['name', 'email']) {
        const input = form.querySelector<HTMLInputElement>(`[name="${field}"]`);
        if (input && !input.reportValidity()) return false;
      }
    }

    if (step === 1 && isTeamEvent) {
      const teamNameInput = form.querySelector<HTMLInputElement>('[name="team_name"]');
      if (teamNameInput && !teamNameInput.reportValidity()) return false;

      const totalMembers = currentMemberCount();
      if (minTeamSize && totalMembers < minTeamSize) {
        setStatus(`This event needs at least ${minTeamSize} members per team (including you) - you currently have ${totalMembers}.`, true);
        return false;
      }

      if (maxTeamSize && totalMembers > maxTeamSize) {
        setStatus(`This event allows at most ${maxTeamSize} members per team (including you) - you currently have ${totalMembers}.`, true);
        return false;
      }
    }

    setStatus();
    return true;
  }

  function reviewItem(label: string, value: string | null | undefined) {
    return `
      <div class="review-field">
        <span>${label}</span>
        <strong>${value || 'Not provided'}</strong>
      </div>
    `;
  }

  function renderReview() {
    if (!reviewPanel) return;

    const teammates = collectTeammates();
    const personalHtml = [
      reviewItem('Name', getFormValue('name')),
      reviewItem('Email', getFormValue('email')),
      reviewItem('Phone', getFormValue('phone')),
    ].join('');
    const collegeHtml = [
      reviewItem('Roll number', getFormValue('roll_number')),
      reviewItem('Branch', getFormValue('branch')),
      reviewItem('Year', getFormValue('year_of_study')),
      reviewItem('Section', getFormValue('section')),
      reviewItem('College', getFormValue('college')),
    ].join('');
    const teamHtml = isTeamEvent
      ? `
        <div class="review-card review-card-team">
          <div class="review-card-heading">
            <span><iconify-icon icon="solar:users-group-rounded-linear" width="18" height="18"></iconify-icon></span>
            <div>
              <p>Team pass</p>
              <h3>Team ticket bundle</h3>
            </div>
          </div>
          <div class="review-list">
            ${reviewItem('Team name', getFormValue('team_name'))}
            ${reviewItem('Total tickets', String(1 + teammates.length))}
          </div>
          ${teammates.length ? `<div class="teammate-review-grid">${teammates.map((member, index) => `
            <div class="teammate-review-card">
              <p>Teammate ${index + 1}</p>
              <div class="review-list">
                ${reviewItem('Name', member.name)}
                ${reviewItem('Email', member.email)}
                ${reviewItem('Phone', member.phone)}
                ${reviewItem('Branch', member.branch)}
              </div>
            </div>
          `).join('')}</div>` : ''}
        </div>
      `
      : `
        <div class="review-card">
          <div class="review-card-heading">
            <span><iconify-icon icon="solar:ticket-sale-linear" width="18" height="18"></iconify-icon></span>
            <div>
              <p>Solo pass</p>
              <h3>Registration type</h3>
            </div>
          </div>
          <div class="review-list">${reviewItem('Ticket mode', 'Solo pass')}</div>
        </div>
      `;

    reviewPanel.innerHTML = `
      <div class="review-card review-card-primary">
        <div class="review-card-heading">
          <span><iconify-icon icon="solar:user-rounded-linear" width="18" height="18"></iconify-icon></span>
          <div>
            <p>Personal</p>
            <h3>Contact details</h3>
          </div>
        </div>
        <div class="review-list">${personalHtml}</div>
      </div>
      <div class="review-card">
        <div class="review-card-heading">
          <span><iconify-icon icon="solar:buildings-2-linear" width="18" height="18"></iconify-icon></span>
          <div>
            <p>College</p>
            <h3>Academic details</h3>
          </div>
        </div>
        <div class="review-list">${collegeHtml}</div>
      </div>
      ${teamHtml}
    `;
  }

  function setStep(step: number) {
    currentStep = Math.max(0, Math.min(maxStep, step));
    stepPanels.forEach((panel, index) => panel.classList.toggle('is-active', index === currentStep));
    stepIndicators.forEach((indicator, index) => {
      indicator.classList.toggle('is-active', index === currentStep);
      indicator.classList.toggle('is-complete', index < currentStep);
    });

    if (backBtn instanceof HTMLButtonElement) backBtn.disabled = currentStep === 0;
    nextBtn?.classList.toggle('hidden', currentStep === maxStep);
    confirmBtn?.classList.toggle('hidden', currentStep !== maxStep);

    if (currentStep === maxStep) renderReview();
  }

  function updateTeamUI() {
    const count = currentMemberCount();
    if (teamCountText) {
      if (minTeamSize && maxTeamSize) {
        teamCountText.textContent = `${count} of ${minTeamSize}–${maxTeamSize} members`;
      } else if (maxTeamSize) {
        teamCountText.textContent = `${count} of up to ${maxTeamSize} members`;
      } else if (minTeamSize) {
        teamCountText.textContent = `${count} members (min ${minTeamSize})`;
      } else {
        teamCountText.textContent = `${count} members`;
      }
    }
    if (addMemberBtn instanceof HTMLButtonElement) {
      addMemberBtn.disabled = Boolean(maxTeamSize && count >= maxTeamSize);
    }
  }

  function wireMemberBlock(block: Element) {
    block.querySelector('.remove-member-btn')?.addEventListener('click', () => {
      block.remove();
      updateTeamUI();
    });

    const sameAsMeCheckbox = block.querySelector('.same-as-me-checkbox');
    sameAsMeCheckbox?.addEventListener('change', (e) => {
      if (!(e.target instanceof HTMLInputElement) || !e.target.checked || !(form instanceof HTMLFormElement)) return;
      for (const field of SAME_AS_ME_FIELDS) {
        const leadValue = getFormValue(field);
        const memberInput = block.querySelector<HTMLInputElement | HTMLSelectElement>(`[data-field="${field}"]`);
        if (!memberInput) continue;
        const matchingOption = memberInput instanceof HTMLSelectElement
          ? [...memberInput.options].some((option) => option.value === leadValue)
          : true;
        memberInput.value = matchingOption ? leadValue : 'Other';
        memberInput.dispatchEvent(new Event('change', { bubbles: true }));
        if (!matchingOption) {
          const otherInput = block.querySelector<HTMLInputElement>(`[data-field="${field}_other"]`);
          if (otherInput) otherInput.value = leadValue;
        }
      }
    });

    wireOtherSelects(block);
  }

  function wireOtherSelects(root: ParentNode = document) {
    root.querySelectorAll<HTMLSelectElement>('[data-other-select]').forEach((select) => {
      const sync = () => {
        const wrapper = select.closest('.field-with-other') || select.parentElement;
        const input = wrapper?.querySelector<HTMLInputElement>('.other-input');
        if (!input) return;
        const show = select.value === 'Other';
        input.classList.toggle('hidden', !show);
        input.required = show;
        if (!show) input.value = '';
      };
      select.addEventListener('change', sync);
      sync();
    });
  }

  teamMembersList?.querySelectorAll('.team-member-block').forEach(wireMemberBlock);
  wireOtherSelects(document);
  updateTeamUI();
  setStep(0);

  nextBtn?.addEventListener('click', () => {
    if (!validateStep(currentStep)) return;
    setStep(currentStep + 1);
  });

  backBtn?.addEventListener('click', () => {
    setStatus();
    setStep(currentStep - 1);
  });

  addMemberBtn?.addEventListener('click', () => {
    if (!(memberTemplate instanceof HTMLTemplateElement) || !teamMembersList) return;
    if (maxTeamSize && currentMemberCount() >= maxTeamSize) return;

    const clone = memberTemplate.content.cloneNode(true) as DocumentFragment;
    const block = clone.querySelector('.team-member-block');
    teamMembersList.appendChild(clone);
    if (block) wireMemberBlock(block);
    updateTeamUI();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!(e.target instanceof HTMLFormElement)) return;

    if (currentStep !== maxStep) {
      if (validateStep(currentStep)) setStep(currentStep + 1);
      return;
    }

    const submitButton = e.target.querySelector('button[type="submit"]');

    const formData = new FormData(e.target);
    const eventId = e.target.dataset.eventId;
    const eventSlug = e.target.dataset.eventSlug;
    const teamName = formData.get('team_name')?.toString().trim() || null;

    const teammates = collectTeammates();

    const totalMembers = 1 + teammates.length;

    if (minTeamSize && totalMembers < minTeamSize) {
      setStatus(`This event needs at least ${minTeamSize} members per team (including you) - you currently have ${totalMembers}.`, true);
      return;
    }

    if (maxTeamSize && totalMembers > maxTeamSize) {
      setStatus(`This event allows at most ${maxTeamSize} members per team (including you) - you currently have ${totalMembers}.`, true);
      return;
    }

    if (minTeamSize && totalMembers < minTeamSize) {
      if (status) {
        status.textContent = `This event needs at least ${minTeamSize} members per team (including you) — you currently have ${totalMembers}.`;
        status.classList.add('text-red-300');
      }
      return;
    }

    if (maxTeamSize && totalMembers > maxTeamSize) {
      if (status) {
        status.textContent = `This event allows at most ${maxTeamSize} members per team (including you) — you currently have ${totalMembers}.`;
        status.classList.add('text-red-300');
      }
      return;
    }

    submitButton?.setAttribute('disabled', 'true');
    if (status) {
      status.textContent = 'Submitting...';
      status.classList.remove('text-red-300');
    }

    const rows = [
      {
        event_id: eventId,
        ticket_id: crypto.randomUUID(),
        team_name: teamName,
        is_team_leader: teammates.length > 0,
        name: getFormValue('name'),
        email: getFormValue('email'),
        phone: getFormValue('phone') || null,
        roll_number: getFormValue('roll_number') || null,
        branch: getFormValue('branch') || null,
        year_of_study: getFormValue('year_of_study') || null,
        section: getFormValue('section') || null,
        college: getFormValue('college') || null,
      },
      ...teammates.map((member) => ({
        event_id: eventId,
        ticket_id: crypto.randomUUID(),
        team_name: teamName,
        is_team_leader: false,
        ...member,
      })),
    ];

    const { data: inserted, error } = await supabase.from('registrations').insert(rows).select('ticket_id');

    if (error) {
      if (status) {
        status.textContent = error.code === '23505'
          ? 'One of the emails entered is already registered for this event.'
          : 'Something went wrong — please try again.';
        status.classList.add('text-red-300');
      }
      submitButton?.removeAttribute('disabled');
      return;
    }

    const ticketIds = (inserted ?? []).map((row) => row.ticket_id).join(',');
    window.location.href = `/events/${eventSlug}/confirmation?tickets=${ticketIds}`;
  });
</script>
