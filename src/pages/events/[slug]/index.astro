---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackgroundShader from '../../../components/BackgroundShader.astro';
import Navbar from '../../../components/Navbar.astro';
import { supabase } from '../../../lib/supabase.js';

export async function getStaticPaths() {
  const { data: events, error } = await supabase.from('events').select('*');

  if (error) {
    console.error('Failed to load events for static paths:', error.message);
    return [];
  }

  return (events ?? []).map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

const formattedDate = new Date(event.date).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

let countdownTarget: string | null = null;
let countdownLabel = '';
if (event.registration_deadline) {
  countdownTarget = new Date(event.registration_deadline).toISOString();
  countdownLabel = 'Registration closes in';
} else {
  const eventDateTime = new Date(event.time ? `${event.date}T${event.time}` : event.date);
  if (!isNaN(eventDateTime.getTime())) {
    countdownTarget = eventDateTime.toISOString();
    countdownLabel = 'Event starts in';
  }
}

function toDisplayList(value: unknown) {
  if (!Array.isArray(value)) return [];
  return value.map((item) =>
    typeof item === 'string' ? item : item?.name ?? JSON.stringify(item)
  );
}

let teamSizeLabel: string | null = null;
if (event.is_team_event) {
  const min = event.min_team_size;
  const max = event.max_team_size;
  if (min && max) {
    teamSizeLabel = min === max ? `${min} members` : `${min}–${max} members`;
  } else if (min) {
    teamSizeLabel = `${min}+ members`;
  } else if (max) {
    teamSizeLabel = `Up to ${max} members`;
  } else {
    teamSizeLabel = 'Team event';
  }
}

const speakers = toDisplayList(event.speakers);
const judges = toDisplayList(event.judges);
const winners = toDisplayList(event.winners);
const chiefGuest =
  event.chief_guest && typeof event.chief_guest === 'object'
    ? event.chief_guest.name ?? JSON.stringify(event.chief_guest)
    : event.chief_guest;
---

<BaseLayout title={`E-Cell VJIT | ${event.title}`}>
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 pt-8 relative z-10">
    <a
      href="/events"
      class="inline-flex items-center gap-2 glass rounded-md px-4 py-2 text-sm font-inter text-gray-200 hover:text-white hover:border-red-500/30 transition-all"
    >
      <iconify-icon icon="solar:arrow-left-linear" width="16" height="16"></iconify-icon>
      Back to Events
    </a>
  </section>

  <!-- Hero -->
  <section class="container mx-auto px-6 py-12 md:py-16 relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <span class="events-ghost-label mx-auto mb-6">{event.mode} &middot; {event.event_type}</span>
      <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-5">{event.title}</h1>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        {event.short_description}
      </p>

      {countdownTarget && (
        <div class="mb-10">
          <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-5">{countdownLabel}</p>
          <div id="countdown" data-target={countdownTarget} class="flex justify-center gap-3 md:gap-5">
            <div class="countdown-box"><span data-unit="days">--</span><small>Days</small></div>
            <div class="countdown-box"><span data-unit="hours">--</span><small>Hours</small></div>
            <div class="countdown-box"><span data-unit="minutes">--</span><small>Minutes</small></div>
            <div class="countdown-box"><span data-unit="seconds">--</span><small>Seconds</small></div>
          </div>
        </div>
      )}

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`/events/${event.slug}/registration`}
          class="hero-action hero-action-primary text-white font-inter font-medium text-base rounded-full px-8 py-4 transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20"
        >
          <span class="hero-action-ring" aria-hidden="true"></span>
          <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
          Register
        </a>
        <a
          href="#details"
          id="know-more-link"
          class="hero-action hero-action-secondary font-inter text-base rounded-full px-8 py-4 transition-all flex items-center justify-center gap-2"
        >
          <span class="hero-action-ring" aria-hidden="true"></span>
          <iconify-icon icon="solar:round-alt-arrow-down-linear" width="20" height="20"></iconify-icon>
          Know more
        </a>
      </div>
    </div>
  </section>

  <!-- Details -->
  <section id="details" class="container mx-auto px-6 pb-16 md:pb-24 relative z-10 max-w-4xl">
    <div class="fire-line-divider mb-10" aria-hidden="true"></div>

    {event.poster_url && (
      <img
        src={event.poster_url}
        alt={`${event.title} poster`}
        class="w-full rounded-2xl mb-10 border border-white/10"
      />
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
      <div class="glass noise-overlay rounded-2xl p-5">
        <p class="text-xs uppercase tracking-[0.2em] text-red-200/80 mb-1">Date &amp; Time</p>
        <p class="font-inter text-white">{formattedDate}{event.time ? ` · ${event.time}` : ''}</p>
      </div>
      <div class="glass noise-overlay rounded-2xl p-5">
        <p class="text-xs uppercase tracking-[0.2em] text-red-200/80 mb-1">Venue</p>
        <p class="font-inter text-white">{event.venue}</p>
      </div>
      {event.is_paid && (
        <div class="glass noise-overlay rounded-2xl p-5">
          <p class="text-xs uppercase tracking-[0.2em] text-red-200/80 mb-1">Price</p>
          <p class="font-inter text-white">₹{event.price}</p>
        </div>
      )}
      {event.prize_pool && (
        <div class="glass noise-overlay rounded-2xl p-5">
          <p class="text-xs uppercase tracking-[0.2em] text-red-200/80 mb-1">Prize Pool</p>
          <p class="font-inter text-white">{event.prize_pool}</p>
        </div>
      )}
      {teamSizeLabel && (
        <div class="glass noise-overlay rounded-2xl p-5">
          <p class="text-xs uppercase tracking-[0.2em] text-red-200/80 mb-1">Team Size</p>
          <p class="font-inter text-white">{teamSizeLabel}</p>
        </div>
      )}
    </div>

    {event.long_description && (
      <div class="mb-10">
        <h2 class="text-2xl font-jakarta font-semibold tracking-tight mb-3">About this event</h2>
        <p class="text-gray-300 font-inter leading-relaxed whitespace-pre-line">{event.long_description}</p>
      </div>
    )}

    {(event.requirements || event.prerequisites) && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        {event.requirements && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Requirements</h3>
            <p class="text-gray-300 font-inter leading-relaxed whitespace-pre-line">{event.requirements}</p>
          </div>
        )}
        {event.prerequisites && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Prerequisites</h3>
            <p class="text-gray-300 font-inter leading-relaxed whitespace-pre-line">{event.prerequisites}</p>
          </div>
        )}
      </div>
    )}

    {(speakers.length > 0 || judges.length > 0 || chiefGuest || winners.length > 0) && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {speakers.length > 0 && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Speakers</h3>
            <ul class="text-gray-300 font-inter space-y-1">
              {speakers.map((name) => <li>{name}</li>)}
            </ul>
          </div>
        )}
        {judges.length > 0 && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Judges</h3>
            <ul class="text-gray-300 font-inter space-y-1">
              {judges.map((name) => <li>{name}</li>)}
            </ul>
          </div>
        )}
        {chiefGuest && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Chief Guest</h3>
            <p class="text-gray-300 font-inter">{chiefGuest}</p>
          </div>
        )}
        {winners.length > 0 && (
          <div>
            <h3 class="text-lg font-jakarta font-semibold mb-2">Winners</h3>
            <ul class="text-gray-300 font-inter space-y-1">
              {winners.map((name) => <li>{name}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .events-ghost-label {
    width: fit-content;
    border-radius: 999px;
    padding: 0.28rem 0.58rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.22);
    background: rgba(127, 29, 29, 0.14);
  }

  .countdown-box {
    min-width: 68px;
    padding: 0.9rem 0.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(165deg, rgba(127, 29, 29, 0.16), rgba(6, 2, 2, 0.36));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .countdown-box span {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: white;
    font-variant-numeric: tabular-nums;
  }

  .countdown-box small {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(254 202 202);
  }

  .hero-action {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-width: min(100%, 15rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 12px 28px rgba(0, 0, 0, 0.22);
  }

  .hero-action::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(254, 202, 202, 0.7), rgba(239, 68, 68, 0.45), rgba(251, 146, 60, 0.8));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0.85;
    transition: opacity 180ms ease, filter 180ms ease;
    pointer-events: none;
  }

  .hero-action-ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .hero-action-primary {
    background: linear-gradient(135deg, rgba(185, 28, 28, 0.96), rgba(249, 115, 22, 0.95));
    color: white;
  }

  .hero-action-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(254, 202, 202, 0.12),
      0 16px 32px rgba(220, 38, 38, 0.22),
      0 0 24px rgba(248, 113, 113, 0.18);
  }

  .hero-action-secondary {
    background: rgba(40, 5, 0, 0.28);
    color: rgb(254 226 226);
  }

  .hero-action-secondary:hover {
    transform: translateY(-1px);
    background: rgba(40, 5, 0, 0.4);
    box-shadow:
      0 0 0 1px rgba(254, 202, 202, 0.14),
      0 12px 28px rgba(0, 0, 0, 0.26),
      0 0 18px rgba(248, 113, 113, 0.12);
  }
</style>

<script>
  const countdownEl = document.getElementById('countdown');

  if (countdownEl instanceof HTMLElement && countdownEl.dataset.target) {
    const target = new Date(countdownEl.dataset.target).getTime();
    const daysEl = countdownEl.querySelector('[data-unit="days"]');
    const hoursEl = countdownEl.querySelector('[data-unit="hours"]');
    const minutesEl = countdownEl.querySelector('[data-unit="minutes"]');
    const secondsEl = countdownEl.querySelector('[data-unit="seconds"]');

    let intervalId: ReturnType<typeof setInterval>;

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        countdownEl.textContent = "It's here!";
        clearInterval(intervalId);
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);

      if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
    };

    tick();
    intervalId = setInterval(tick, 1000);
  }

  document.getElementById('know-more-link')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('details')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
